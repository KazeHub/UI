		local dialogStroke = Instance.new("UIStroke", dialogPanel)
		dialogStroke.Thickness = 1.5
		KazeUI:RegisterBorder(dialogStroke)

		-- Icon Render
		local hasDIcon = (dIcon ~= "")
		local textLeftMargin = hasDIcon and 68 or 16
		local maxDialogTextWidth = 340 - textLeftMargin - 16

		if hasDIcon then
			local dIconLabel = Instance.new("ImageLabel", dialogPanel)
			dIconLabel.Size = UDim2.fromOffset(36, 36)
			dIconLabel.Position = UDim2.fromOffset(16, 16)
			dIconLabel.BackgroundTransparency = 1
			dIconLabel.Image = dIcon
			KazeUI:OnThemeChanged(dIconLabel, function(t) dIconLabel.ImageColor3 = t.Text end)
		end

		local dialogTitle = Instance.new("TextLabel", dialogPanel)
		dialogTitle.Size = UDim2.new(0, maxDialogTextWidth, 0, 20)
		dialogTitle.Position = UDim2.fromOffset(textLeftMargin, 16)
		dialogTitle.BackgroundTransparency = 1
		dialogTitle.Text = dTitle
		dialogTitle.Font = Enum.Font.GothamBold
		dialogTitle.TextSize = 14
		dialogTitle.TextXAlignment = Enum.TextXAlignment.Left
		KazeUI:RegisterText(dialogTitle, false)

		local dialogContent = Instance.new("TextLabel", dialogPanel)
		dialogContent.Size = UDim2.new(0, maxDialogTextWidth, 0, 72)
		dialogContent.Position = UDim2.fromOffset(textLeftMargin, 40)
		dialogContent.BackgroundTransparency = 1
		dialogContent.Text = dContent
		dialogContent.Font = Enum.Font.GothamMedium
		dialogContent.TextSize = 12
		dialogContent.TextWrapped = true
		dialogContent.TextXAlignment = Enum.TextXAlignment.Left
		dialogContent.TextYAlignment = Enum.TextYAlignment.Top
		KazeUI:RegisterText(dialogContent, true)

		-- Dynamic Actions Auto-Stacker Alignments System
		local actionCount = #dActions
		local stackVertically = (actionCount >= 4)

		local actionContainer = Instance.new("Frame", dialogPanel)
		actionContainer.BackgroundTransparency = 1
		
		local function closeDialog()
			activeDialogsCount = math.max(0, activeDialogsCount - 1)
			TweenService:Create(dialogPanel, TWEEN_FAST, {Position = UDim2.fromScale(0.5, 0.35)}):Play()
			TweenService:Create(dialogOverlay, TWEEN_FAST, {BackgroundTransparency = 1}):Play()
			task.wait(0.18)
			dialogOverlay:Destroy()
		end

		if stackVertically then
			-- Calculate stacked layout size constraints dynamically
			local buttonHeight = 32
			local buttonGap = 6
			local containerHeight = (buttonHeight * actionCount) + (buttonGap * (actionCount - 1))
			
			dialogPanel.Size = UDim2.fromOffset(340, 130 + containerHeight)
			actionContainer.Size = UDim2.new(1, -32, 0, containerHeight)
			actionContainer.Position = UDim2.fromOffset(16, 110)

			local verticalLayout = Instance.new("UIListLayout", actionContainer)
			verticalLayout.FillDirection = Enum.FillDirection.Vertical
			verticalLayout.Padding = UDim.new(0, buttonGap)
			verticalLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
		else
			-- Align Horizontally 
			dialogPanel.Size = UDim2.fromOffset(340, 175)
			actionContainer.Size = UDim2.new(1, -32, 0, 36)
			actionContainer.Position = UDim2.fromOffset(16, 122)

			local horizontalLayout = Instance.new("UIListLayout", actionContainer)
			horizontalLayout.FillDirection = Enum.FillDirection.Horizontal
			horizontalLayout.Padding = UDim.new(0, 8)
			horizontalLayout.HorizontalAlignment = Enum.HorizontalAlignment.Right
		end

		for _, action in ipairs(dActions) do
			local buttonWidth = stackVertically and UDim2.fromScale(1, 0) or UDim2.fromOffset(math.clamp(280 / actionCount, 60, 110), 32)
			local actBtn = Instance.new("TextButton", actionContainer)
			actBtn.Size = stackVertically and UDim2.new(1, 0, 0, 32) or buttonWidth
			actBtn.BorderSizePixel = 0
			actBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
			actBtn.Text = tostring(action.Name or "Ok")
			actBtn.Font = Enum.Font.GothamBold
			actBtn.TextSize = 11
			actBtn.TextWrapped = true
			actBtn.TextScaled = true

			local tsConstraint = Instance.new("UITextSizeConstraint", actBtn)
			tsConstraint.MaxTextSize = 12

			Instance.new("UICorner", actBtn).CornerRadius = UDim.new(0, 8)
			KazeUI:AddPanel(actBtn, 0.15, true, false)

			local actionColor = action.Color
			if typeof(actionColor) == "Color3" then
				actBtn.BackgroundColor3 = actionColor
				actBtn.TextColor3 = Color3.new(255, 255, 255)
			elseif type(actionColor) == "string" then
				local sH, col = pcall(Color3.fromHex, actionColor)
				if sH and col then
					actBtn.BackgroundColor3 = col
					actBtn.TextColor3 = Color3.new(255, 255, 255)
				end
			else
				KazeUI:RegisterText(actBtn, false)
			end

			local btnOutline = Instance.new("UIStroke", actBtn)
			btnOutline.Thickness = 1
			KazeUI:RegisterBorder(btnOutline)

			actBtn.MouseButton1Click:Connect(function()
				closeDialog()
				if action.Callback then
					task.spawn(action.Callback)
				end
			end)
		end

		-- Panel Entrance Tweens animation
		dialogPanel.Position = UDim2.fromScale(0.5, 0.45)
		TweenService:Create(dialogPanel, TWEEN_SPRING, {Position = UDim2.fromScale(0.5, 0.5)}):Play()
	end

