local function FormatImage(id)
	if not id or id == "" then return "" end
	id = tostring(id)
	if string.find(id, "rbxassetid://") then return id end
	if string.find(id, "^http") then return id end
	local clean = string.gsub(id, "%D", "")
	if clean == "" then return id end
	return "rbxassetid://" .. clean
end

-- Lexical scan highlight algorithm
local function HighlightCode(source)
	local tokens = {}
	local length = #source
	local index = 1

	while index <= length do
		local char = string.sub(source, index, index)
		if char == "-" and string.sub(source, index + 1, index + 1) == "-" then
			local commentStart = index
			while index <= length and string.sub(source, index, index) ~= "\n" do
				index = index + 1
			end
			table.insert(tokens, {source:sub(commentStart, index - 1), HighlightColors.Comments})
		elseif char == '"' or char == "'" then
			local quote = char
			local start = index
			index = index + 1
			while index <= length and string.sub(source, index, index) ~= quote do
				index = index + 1
			end
			index = index + 1
			table.insert(tokens, {source:sub(start, index - 1), HighlightColors.Strings})
		elseif char:match("%d") then
			local start = index
			while index <= length and string.sub(source, index, index):match("[%d%.]") do
				index = index + 1
			end
			table.insert(tokens, {source:sub(start, index - 1), HighlightColors.Numbers})
		elseif char:match("[%a_]") then
			local start = index
			while index <= length and string.sub(source, index, index):match("[%w_]") do
				index = index + 1
			end
			local word = source:sub(start, index - 1)
			if LuaKeywords[word] then
				table.insert(tokens, {word, HighlightColors.LuaKeyword})
			elseif RobloxGlobals[word] then
				table.insert(tokens, {word, HighlightColors.RobloxGlobals})
			else
				table.insert(tokens, {word, HighlightColors.Text})
			end
		elseif char:match("[%+%-%*%/%^%%#=~<>%.,:;{}%(%)%[%]]") then
			table.insert(tokens, {char, HighlightColors.Operators})
			index = index + 1
		else
			table.insert(tokens, {char, HighlightColors.Text})
			index = index + 1
		end
	end

	local output = ""
	for _, token in ipairs(tokens) do
		local color = token[2]
		local cleanText = token[1]:gsub("&", "&amp;"):gsub("<", "&lt;"):gsub(">", "&gt;")
		output = output .. string.format('<font color="rgb(%d,%d,%d)">%s</font>', math.floor(color.R*255), math.floor(color.G*255), math.floor(color.B*255), cleanText)
	end
	return output
end

-- ==========================================
-- Theme Color Translators
-- ==========================================
function KazeUI:RegisterText(inst, isMuted)
	if not inst then return end
	if isMuted then
		table.insert(KazeUI.MutedTextElements, inst)
		inst.TextColor3 = KazeUI.CurrentTheme.MutedText
	else
		table.insert(KazeUI.TextElements, inst)
		inst.TextColor3 = KazeUI.CurrentTheme.Text
	end
	inst.Destroying:Connect(function()
		local list = isMuted and KazeUI.MutedTextElements or KazeUI.TextElements
		for i = #list, 1, -1 do
			if list[i] == inst then table.remove(list, i) end
		end
	end)
end

function KazeUI:RegisterBorder(inst)
	if not inst then return end
	table.insert(KazeUI.BorderElements, inst)
	inst.Color = KazeUI.CurrentTheme.Border
	inst.Destroying:Connect(function()
		for i = #KazeUI.BorderElements, 1, -1 do
			if KazeUI.BorderElements[i] == inst then table.remove(KazeUI.BorderElements, i) end
		end
	end)
end

function KazeUI:OnThemeChanged(inst, cb)
	if not inst then return end
	table.insert(KazeUI.ThemeCallbacks, {Inst = inst, Callback = cb})
	task.spawn(cb, KazeUI.CurrentTheme)
end

function KazeUI.GetColor(elevation)
	local theme = KazeUI.CurrentTheme
	local h, s, v = Color3.toHSV(theme.Background)
	local factor = theme.LightnessFactor or 1
	local offset = elevation * factor * 2.2
	return Color3.fromHSV(h, math.clamp(s - (elevation * 0.5), 0, 1), math.clamp(v + offset, 0, 1))
end

function KazeUI:AddPanel(inst, elevation, ignoreColor, ignoreTrans)
	table.insert(KazeUI.PanelElements, {Inst = inst, Elevation = elevation or 0, IgnoreColor = ignoreColor, IgnoreTrans = ignoreTrans})
	if inst and inst:IsA("GuiObject") then
		if not ignoreColor then inst.BackgroundColor3 = KazeUI.GetColor(elevation or 0) end
		if not ignoreTrans then inst.BackgroundTransparency = KazeUI.BackgroundTransparency end
	end
end

function KazeUI:SetTheme(themeName)
	local targetTheme = KazeUI.Themes[themeName] or KazeUI.Themes.CustomWallpaper
	KazeUI.CurrentTheme = targetTheme
	
	for _, inst in ipairs(KazeUI.TextElements) do if inst.Parent then inst.TextColor3 = targetTheme.Text end end
	for _, inst in ipairs(KazeUI.MutedTextElements) do if inst.Parent then inst.TextColor3 = targetTheme.MutedText end end
	for _, inst in ipairs(KazeUI.BorderElements) do if inst.Parent then inst.Color = targetTheme.Border end end
	for _, data in ipairs(KazeUI.ThemeCallbacks) do if data.Inst.Parent then pcall(data.Callback, targetTheme) end end
end

