local AcrylicFolder = Instance.new("Folder")
AcrylicFolder.Name = "KazeUI_AcrylicEffects"
AcrylicFolder.Parent = Camera

local function CreateAcrylicEffect(frame)
	local AcrylicModel = Instance.new("Part")
	AcrylicModel.Name = "AcrylicGlass"
	AcrylicModel.Material = Enum.Material.Glass
	AcrylicModel.Color = Color3.fromRGB(0, 0, 0)
	AcrylicModel.Transparency = 0.98
	AcrylicModel.Anchored = true
	AcrylicModel.CanCollide = false
	AcrylicModel.CastShadow = false
	AcrylicModel.Size = Vector3.new(1, 1, 0.01)
	AcrylicModel.Parent = AcrylicFolder

	local mesh = Instance.new("SpecialMesh", AcrylicModel)
	mesh.MeshType = Enum.MeshType.Brick

	local dof = Lighting:FindFirstChildOfClass("DepthOfFieldEffect")
	if not dof then
		dof = Instance.new("DepthOfFieldEffect")
		dof.FarIntensity = 0
		dof.InFocusRadius = 0.1
		dof.NearIntensity = 1
		dof.Enabled = true
		dof.Parent = Lighting
	end

	local function update()
		if not frame or not frame.Parent or not AcrylicModel.Parent then return end
		local size = frame.AbsoluteSize
		local pos = frame.AbsolutePosition
		local viewport = Camera.ViewportSize

		if viewport.X == 0 or viewport.Y == 0 then return end

		local depth = 0.1
		local cornerPos = Camera:ScreenPointToRay(pos.X + size.X/2, pos.Y + size.Y/2, depth)
		AcrylicModel.CFrame = CFrame.new(cornerPos.Origin) * Camera.CFrame.Rotation
		AcrylicModel.Size = Vector3.new(size.X * 0.002, size.Y * 0.002, 0.01)
	end

	local conn = RunService.RenderStepped:Connect(update)
	frame.Destroying:Connect(function()
		conn:Disconnect()
		AcrylicModel:Destroy()
	end)

	return AcrylicModel
end

