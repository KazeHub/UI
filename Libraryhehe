						elseif not gpe and input.KeyCode == currentBind then
							if kbCallback then kbCallback(currentBind) end
						end
					end)

					RegisterFlag(kbFlag, function() return currentBind end, function(v)
						currentBind = v
						kbBtn.Text = currentBind.Name
					end)
				end

				return GrpObj
			end

			-- Double map Group as GroupBox to allow 100% backwards compatibility with showcase templates
			SecUIObj.Group = SecUIObj.GroupBox

			return SecUIObj
		end

		return tabObj
	end

	-- THEME MANAGER DYNAMIC PANEL CREATION METHOD
	function WindowObj:CreateThemeManager(targetTabObj)
		if not targetTabObj then return end
		targetTabObj:Section("Theme Manager")

		targetTabObj:Dropdown({
			Title = "Selected Theme Preset",
			Description = "Select a preset visual skin overlay.",
			Options = {"Obsidian", "CustomWallpaper"},
			Default = "CustomWallpaper",
			Callback = function(themeName)
				KazeUI:SetTheme(themeName)
			end
		})

		targetTabObj:Slider({
			Title = "Glow Brightness Factor",
			Description = "Tweak the breathing line outline accent glow.",
			Min = 0,
			Max = 100,
			Default = 50,
			Callback = function(val)
				local fraction = val / 100
				local col = Color3.fromHSV(fraction, 1, 1)
				KazeUI:SetGlow(col)
			end
		})

		targetTabObj:Slider({
			Title = "Background Transparency",
			Description = "Control translucent acrylic overlay.",
			Min = 0,
			Max = 100,
			Default = 70,
			Callback = function(val)
				KazeUI:SetTransparency(val / 100)
			end
		})
	end

	-- CONFIGURATION MANAGER METHOD
	function WindowObj:CreateConfigManager(targetTabObj)
		if not targetTabObj then return end
		targetTabObj:Section("Config Presets Manager")

		local configNameText = "NewPreset"
		targetTabObj:TextBox({
			Title = "Preset Target Name",
			Description = "Input target configurations file name.",
			Placeholder = "NewPreset",
			Callback = function(text)
				if text ~= "" then configNameText = text end
			end
		})

		targetTabObj:Button({
			Title = "Save Current Configuration",
			Description = "Serialize all active toggles/sliders states.",
			Callback = function()
				KazeUI:SaveConfig(configNameText)
			end
		})

		targetTabObj:Button({
			Title = "Load Saved Preset",
			Description = "Fetch state configurations profiles.",
			Callback = function()
				KazeUI:LoadConfig(configNameText)
			end
		})
	end

	-- Set Initial Theme & Glow Accents
	KazeUI:SetTheme(initialTheme)
	KazeUI:SetGlow(initialGlow)

	return WindowObj
end

return KazeUI
