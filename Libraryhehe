	function WindowObj:Dialog(dialogConfig)
		dialogConfig = dialogConfig or {}
		local dTitle = tostring(dialogConfig.Title or "Verification Required")
		local dContent = tostring(dialogConfig.Content or "")
		local dIcon = dialogConfig.Icon and FormatImage(dialogConfig.Icon) or ""
		local dActions = dialogConfig.Actions or {}

		activeDialogsCount = activeDialogsCount + 1

		local dialogOverlay = Instance.new("TextButton")
		dialogOverlay.Name = "DialogLockOverlay"
		dialogOverlay.Size = UDim2.fromScale(1, 1)
		dialogOverlay.BackgroundTransparency = 0.45
