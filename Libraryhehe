		local dialogPanel = Instance.new("Frame")
		dialogPanel.Name = "DialogPanel"
		dialogPanel.Size = UDim2.fromOffset(340, 200)
		dialogPanel.AnchorPoint = Vector2.new(0.5, 0.5)
