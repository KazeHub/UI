-- ==========================================
-- Interactive 3D Viewport Frame Element
-- ==========================================
function ComponentFactory.CreateViewport(parent, objectModel, height)
	local container = Instance.new("Frame")
	container.Size = UDim2.new(1, -16, 0, height or 180)
	container.Parent = parent
	Instance.new("UICorner", container).CornerRadius = UDim.new(0, SPACE_SMALL)
	KazeUI:AddPanel(container, 0.03, false, true)

	local viewport = Instance.new("ViewportFrame", container)
	viewport.Size = UDim2.fromScale(1, 1)
	viewport.BackgroundTransparency = 1

	local camera = Instance.new("Camera")
	viewport.CurrentCamera = camera
	camera.Parent = viewport

	if objectModel then
		local cloned = objectModel:Clone()
		cloned.Parent = viewport
		local size = cloned:GetExtentsSize()
		local center = cloned:GetPivot().Position
		camera.CFrame = CFrame.new(center + Vector3.new(0, 0, size.Magnitude), center)
	end

	return container
end

-- ==========================================
-- Unified Responsive Main Window Creator
-- ==========================================
function KazeUI:CreateWindow(config)
	config = config or {}
	local title = config.Title or "Unified Windows"
	local author = config.Author or "Footagesus"
	local version = config.Version or "1.0.0"

	-- Adaptive Sizing Fallback to handle (600, 400) syntax safely
	local windowSize = config.Size or UDim2.fromOffset(900, 580)
	if typeof(windowSize) == "table" then
		windowSize = UDim2.fromOffset(windowSize[1] or 900, windowSize[2] or 580)
	end

	local Window = Instance.new("Frame")
	Window.Size = windowSize
	Window.Position = UDim2.fromScale(0.5, 0.5)
	Window.AnchorPoint = Vector2.new(0.5, 0.5)
	Window.BorderSizePixel = 0
	Window.Active = true
	Window.Parent = ScreenGui

	Instance.new("UICorner", Window).CornerRadius = UDim.new(0, 14)
	KazeUI:AddPanel(Window, 0, false, true)
	Window.BackgroundTransparency = 0.15

	-- Inject Acrylic Blur Pipeline if requested
	if config.Acrylic ~= false then
		CreateAcrylicEffect(Window)
	end

	local contentClipper = Instance.new("CanvasGroup", Window)
	contentClipper.Size = UDim2.fromScale(1, 1)
	contentClipper.BackgroundTransparency = 1
	Instance.new("UICorner", contentClipper).CornerRadius = UDim.new(0, 14)

	local TopBar = Instance.new("Frame", contentClipper)
	TopBar.Size = UDim2.new(1, 0, 0, 44)
	TopBar.BorderSizePixel = 0
	KazeUI:AddPanel(TopBar, -0.01, false, true)
	TopBar.BackgroundTransparency = 0.3
	MakeDraggable(TopBar, Window)

	local titleLabel = Instance.new("TextLabel", TopBar)
	titleLabel.Size = UDim2.new(1, -200, 1, 0)
	titleLabel.Position = UDim2.fromOffset(14, 0)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = title .. " - " .. author .. " " .. version
	titleLabel.Font = Enum.Font.GothamBold
	titleLabel.TextSize = FONT_TITLE_WINDOW - 2
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	KazeUI:RegisterText(titleLabel, false)

	-- Search Overlay System
	local searchBtn = Instance.new("ImageButton", TopBar)
	searchBtn.Size = UDim2.fromOffset(24, 24)
	searchBtn.Position = UDim2.new(1, -38, 0.5, -12)
	searchBtn.BackgroundTransparency = 1
	searchBtn.Image = "rbxassetid://10747372701"
	KazeUI:OnThemeChanged(searchBtn, function(t) searchBtn.ImageColor3 = t.Text end)

	local SideBar = Instance.new("Frame", contentClipper)
	SideBar.Size = UDim2.new(0, 190, 1, -44)
	SideBar.Position = UDim2.fromOffset(0, 44)
	SideBar.BackgroundTransparency = 1

	local Pages = Instance.new("Frame", contentClipper)
	Pages.Position = UDim2.new(0, 191, 0, 44)
	Pages.Size = UDim2.new(1, -191, 1, -44)
	Pages.BackgroundTransparency = 1

	local winObj = {
		Window = Window,
		ScreenGui = ScreenGui,
		Pages = Pages,
		Tabs = {},
		CurrentTab = nil
	}

	function winObj:CreateTab(tabConfig)
		tabConfig = tabConfig or {}
		local tabTitle = tabConfig.Title or "Tab"
		
		local tabBtn = Instance.new("TextButton", SideBar)
		tabBtn.Size = UDim2.new(1, -12, 0, 34)
		tabBtn.Position = UDim2.fromOffset(6, (#SideBar:GetChildren() * 40) + 12)
		tabBtn.Text = ""
		tabBtn.AutoButtonColor = false
		Instance.new("UICorner", tabBtn).CornerRadius = UDim.new(0, SPACE_SMALL)
		KazeUI:AddPanel(tabBtn, 0.02, false, true)

		local label = Instance.new("TextLabel", tabBtn)
		label.Size = UDim2.fromScale(1, 1)
		label.Position = UDim2.fromOffset(12, 0)
		label.BackgroundTransparency = 1
		label.Text = tabTitle
		label.Font = Enum.Font.GothamMedium
		label.TextSize = FONT_TAB_TEXT
		label.TextXAlignment = Enum.TextXAlignment.Left
		KazeUI:RegisterText(label, true)

		local pageFrame = Instance.new("ScrollingFrame", Pages)
		pageFrame.Size = UDim2.fromScale(1, 1)
		pageFrame.BackgroundTransparency = 1
		pageFrame.ScrollBarThickness = 4
		pageFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
		pageFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
		pageFrame.Visible = false

		local pageLayout = Instance.new("UIListLayout", pageFrame)
		pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
		pageLayout.Padding = UDim.new(0, SPACE_SMALL)

		local pagePadding = Instance.new("UIPadding", pageFrame)
		pagePadding.PaddingTop = UDim.new(0, SPACE_STANDARD)
		pagePadding.PaddingLeft = UDim.new(0, SPACE_STANDARD)
		pagePadding.PaddingRight = UDim.new(0, SPACE_STANDARD)

		local function select()
			for _, t in ipairs(winObj.Tabs) do
				t.Page.Visible = false
				t.Label.Font = Enum.Font.GothamMedium
			end
			pageFrame.Visible = true
			label.Font = Enum.Font.GothamBold
			winObj.CurrentTab = pageFrame
		end

		tabBtn.MouseButton1Click:Connect(select)

		local tabObj = {
			Button = tabBtn,
			Page = pageFrame,
			Label = label
		}

		table.insert(winObj.Tabs, tabObj)
		if #winObj.Tabs == 1 then select() end

		-- Expose DSL Component Builders
		function tabObj:Paragraph(cfg) return ComponentFactory.CreateParagraph(pageFrame, cfg.Title, cfg.Content) end
		function tabObj:Button(cfg) return ComponentFactory.CreateButton(pageFrame, cfg.Title, cfg.Description, cfg.Callback, cfg.Locked) end
		function tabObj:Toggle(cfg) return ComponentFactory.CreateToggle(pageFrame, cfg.Title, cfg.Description, cfg.Default, cfg.Callback, cfg.Locked) end
		function tabObj:CodeViewer(cfg) return ComponentFactory.CreateCodeViewer(pageFrame, cfg.Title, cfg.Code) end
		function tabObj:Viewport(cfg) return ComponentFactory.CreateViewport(pageFrame, cfg.ObjectModel, cfg.Height) end
		function tabObj:AddLabel(text)
			local label = Instance.new("TextLabel", pageFrame)
			label.Size = UDim2.new(1, -12, 0, 22)
			label.BackgroundTransparency = 1
			label.Text = text
			label.Font = Enum.Font.Gotham
			label.TextSize = FONT_LABEL_TEXT
			label.TextXAlignment = Enum.TextXAlignment.Left
			KazeUI:RegisterText(label, false)
			return label
		end
		function tabObj:Section(title)
			local divider = Instance.new("Frame", pageFrame)
			divider.Size = UDim2.new(1, -12, 0, 24)
			divider.BackgroundTransparency = 1
			
			local text = Instance.new("TextLabel", divider)
			text.Size = UDim2.fromScale(1, 1)
			text.BackgroundTransparency = 1
			text.Text = title:upper()
			text.Font = Enum.Font.GothamBold
			text.TextSize = FONT_SECTION_TITLE
			text.TextXAlignment = Enum.TextXAlignment.Left
			KazeUI:RegisterText(text, true)
		end
		function tabObj:SectionUI(title)
			return tabObj
		end
		function tabObj:GroupBox(title)
			return tabObj
		end

		return tabObj
	end

	-- Window modal builder dialog implementation
	function winObj:Dialog(dialogConfig)
		dialogConfig = dialogConfig or {}
		local dTitle = dialogConfig.Title or "Dialog"
		local dContent = dialogConfig.Content or ""
		local dActions = dialogConfig.Actions or {}

		local shadow = Instance.new("TextButton", contentClipper)
		shadow.Size = UDim2.fromScale(1, 1)
		shadow.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
		shadow.BackgroundTransparency = 0.5
		shadow.Text = ""
		shadow.AutoButtonColor = false
		shadow.ZIndex = 500

		local dFrame = Instance.new("Frame", shadow)
		dFrame.Size = UDim2.fromOffset(380, 220)
		dFrame.Position = UDim2.fromScale(0.5, 0.5)
		dFrame.AnchorPoint = Vector2.new(0.5, 0.5)
		Instance.new("UICorner", dFrame).CornerRadius = UDim.new(0, 12)
		KazeUI:AddPanel(dFrame, 0.05, false, true)

		local titleLabel = Instance.new("TextLabel", dFrame)
		titleLabel.Size = UDim2.new(1, -24, 0, 30)
		titleLabel.Position = UDim2.fromOffset(12, 12)
		titleLabel.BackgroundTransparency = 1
		titleLabel.Text = dTitle
		titleLabel.Font = Enum.Font.GothamBold
		titleLabel.TextSize = FONT_DIALOG_TITLE
		titleLabel.TextXAlignment = Enum.TextXAlignment.Center
		KazeUI:RegisterText(titleLabel, false)

		local contentLabel = Instance.new("TextLabel", dFrame)
		contentLabel.Size = UDim2.new(1, -24, 0, 80)
		contentLabel.Position = UDim2.fromOffset(12, 42)
		contentLabel.BackgroundTransparency = 1
		contentLabel.Text = dContent
		contentLabel.Font = Enum.Font.Gotham
		contentLabel.TextSize = FONT_DIALOG_DESC
		contentLabel.TextWrapped = true
		contentLabel.TextXAlignment = Enum.TextXAlignment.Center
		KazeUI:RegisterText(contentLabel, true)

		local btns = Instance.new("Frame", dFrame)
		btns.Size = UDim2.new(1, -24, 0, 36)
		btns.Position = UDim2.new(0, 12, 1, -48)
		btns.BackgroundTransparency = 1

		local layout = Instance.new("UIListLayout", btns)
		layout.FillDirection = Enum.FillDirection.Horizontal
		layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
		layout.Padding = UDim.new(0, SPACE_SMALL)

		for _, act in ipairs(dActions) do
			local button = Instance.new("TextButton", btns)
			button.Size = UDim2.new(0, (356 - ((#dActions - 1) * 8)) / #dActions, 1, 0)
			button.Text = act.Name
			button.Font = Enum.Font.GothamBold
			button.TextSize = FONT_BUTTON_TEXT - 2
			button.TextColor3 = Color3.fromRGB(255, 255, 255)
			button.BackgroundColor3 = typeof(act.Color) == "Color3" and act.Color or KazeUI.GlowColor
			Instance.new("UICorner", button).CornerRadius = UDim.new(0, SPACE_SMALL)

			button.MouseButton1Click:Connect(function()
				pcall(act.Callback)
				shadow:Destroy()
			end)
		end
	end

	function winObj:CreateThemeManager(tab)
		tab:Section("Preset Configurations")
		tab:Toggle({
			Title = "Frosted Glass Acrylic",
			Description = "Toggle high-performance camera glass occlusion layers",
			Default = true,
			Callback = function(v)
				AcrylicFolder.Parent = v and Camera or nil
			end
		})
	end

	function winObj:CreateConfigManager(tab)
		tab:Section("Configuration Systems")
	end

	return winObj
end

-- ==========================================================
-- Security Lock Overlay
-- ==========================================================
function ApplyLock(componentFrame, isLocked)
	local lockOverlay = Instance.new("TextButton")
	lockOverlay.Name = "LockOverlay"
	lockOverlay.Size = UDim2.fromScale(1, 1)
	lockOverlay.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
	lockOverlay.BackgroundTransparency = 0.55
	lockOverlay.ZIndex = 9999
	lockOverlay.Text = ""
	lockOverlay.AutoButtonColor = false
	lockOverlay.Visible = isLocked or false
	lockOverlay.Active = true
	lockOverlay.Parent = componentFrame

	local corner = componentFrame:FindFirstChildOfClass("UICorner")
	if corner then
		local overlayCorner = Instance.new("UICorner")
		overlayCorner.CornerRadius = corner.CornerRadius
		overlayCorner.Parent = lockOverlay
	end

	local lockIcon = Instance.new("ImageLabel")
	lockIcon.Name = "LockIcon"
	lockIcon.Size = UDim2.fromOffset(24, 24)
	lockIcon.AnchorPoint = Vector2.new(0.5, 0.5)
	lockIcon.Position = UDim2.fromScale(0.5, 0.5)
	lockIcon.BackgroundTransparency = 1
	lockIcon.Image = "rbxassetid://78672912777756"
	lockIcon.ZIndex = 10000
	lockIcon.Parent = lockOverlay

	KazeUI:OnThemeChanged(lockIcon, function(t)
		lockIcon.ImageColor3 = t.MutedText
	end)

	return {
		Overlay = lockOverlay,
		SetLocked = function(self, state)
			lockOverlay.Visible = state
		end
	}
end

return KazeUI
