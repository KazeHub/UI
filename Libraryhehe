				function GrpObj:Slider(sConfig)
					sConfig = sConfig or {}
					local sMin = sConfig.Min or 0
					local sMax = sConfig.Max or 100
					local sDefault = math.clamp(sConfig.Default or sMin, sMin, sMax)
					local sCallback = sConfig.Callback
					local sFlag = sConfig.Flag
					local currentVal = sDefault

					local compFrame, rightArea, lockHook = CreateInteractiveComponent(groupFrame, "Slider", sConfig)

					local sliderTrack = Instance.new("TextButton", rightArea)
					sliderTrack.Size = UDim2.fromOffset(110, 8)
					sliderTrack.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
					sliderTrack.BorderSizePixel = 0
					sliderTrack.Text = ""
					
					Instance.new("UICorner", sliderTrack).CornerRadius = UDim.new(1, 0)

					local sliderFill = Instance.new("Frame", sliderTrack)
					sliderFill.Size = UDim2.fromScale(0.5, 1)
					sliderFill.BackgroundColor3 = KazeUI.GlowColor
					sliderFill.BorderSizePixel = 0
					
					Instance.new("UICorner", sliderFill).CornerRadius = UDim.new(1, 0)

					local sliderValLabel = Instance.new("TextLabel", rightArea)
					sliderValLabel.Size = UDim2.fromOffset(36, 18)
					sliderValLabel.BackgroundTransparency = 1
					sliderValLabel.Text = tostring(currentVal)
					sliderValLabel.Font = Enum.Font.GothamBold
					sliderValLabel.TextSize = 10
					KazeUI:RegisterText(sliderValLabel, false)

					local function updateSlider(val)
						val = math.clamp(val, sMin, sMax)
						currentVal = val
						sliderValLabel.Text = tostring(val)
						
						local pct = (val - sMin) / (sMax - sMin)
						sliderFill.Size = UDim2.fromScale(pct, 1)
					end

					local sliding = false
					local function handleDrag(input)
						local trackSize = sliderTrack.AbsoluteSize.X
						local trackPos = sliderTrack.AbsolutePosition.X
						local delta = math.clamp((input.Position.X - trackPos) / trackSize, 0, 1)
						local newVal = math.round(sMin + (delta * (sMax - sMin)))
						updateSlider(newVal)
						if sCallback then sCallback(newVal) end
					end

					sliderTrack.InputBegan:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
							sliding = true
							handleDrag(input)
						end
					end)

					UIS.InputChanged:Connect(function(input)
						if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
							handleDrag(input)
						end
					end)

					UIS.InputEnded:Connect(function(input)
						if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
							sliding = false
						end
					end)

					updateSlider(sDefault)

					RegisterFlag(sFlag, function() return currentVal end, function(v) updateSlider(v) end)
				end

