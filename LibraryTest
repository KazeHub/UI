	function apiTable:Dropdown(arg1, arg2, arg3, arg4, arg5, arg6)
		local target, isGrouped = getTarget()
		local title, vals, def, callback, multi, flag
		if type(arg1) == "table" then title, vals, def, multi, callback, flag = arg1.Title, (arg1.Values or arg1.Options), arg1.Default, (arg1.Multi or false), arg1.Callback, arg1.Flag
		else title, vals, def, callback, multi, flag = arg1, arg2, arg3, arg4, (arg5 or false), arg6 end
		local el = CreateDropdown(target, title, vals, def, callback, multi, flag, isGrouped)
		apiTable:SetGroupedElement(el)
		return el
	end

	function apiTable:ColorPicker(arg1, arg2, arg3, arg4)
		local target, isGrouped = getTarget()
		local title, def, cb, flag
		if type(arg1) == "table" then title, def, cb, flag = arg1.Title, arg1.Default, arg1.Callback, arg1.Flag
		else title, def, cb, flag = arg1, arg2, arg3, arg4 end
		local el = CreateColorPicker(target, title, def, cb, flag, isGrouped)
		apiTable:SetGroupedElement(el)
		return el
	end
	
	function apiTable:Keybind(arg1, arg2, arg3, arg4)
		local target, isGrouped = getTarget()
		local title, def, cb, flag
		if type(arg1) == "table" then title, def, cb, flag = arg1.Title, arg1.Default, arg1.Callback, arg1.Flag
		else title, def, cb, flag = arg1, arg2, arg3, arg4 end
		local el = CreateKeybindInput(target, title, def, cb, flag, isGrouped)
		apiTable:SetGroupedElement(el)
		return el
	end

	function apiTable:SectionUI(arg1)
		local title = type(arg1) == "table" and arg1.Title or arg1
		self.CurrentGroup, self.LastGroupElement = nil, nil
		return CreateCollapsibleSection(parentFrame, title)
	end
	
	function apiTable:Section(arg1)
		local title = type(arg1) == "table" and arg1.Title or arg1
		self.CurrentGroup, self.LastGroupElement = nil, nil
		return CreateVisualSectionDivider(parentFrame, title)
	end
end

