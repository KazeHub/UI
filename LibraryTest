		else
			TweenService:Create(arrowIcon, tInfo, {Rotation = -90, ImageColor3 = KazeUI.CurrentTheme.MutedText}):Play()
			TweenService:Create(accentLine, tInfo, {BackgroundColor3 = KazeUI.CurrentTheme.MutedText}):Play()
