	local function toggleSection()
		isOpen = not isOpen
		sectionContent.Visible, divider.Visible = isOpen, isOpen

		local tInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		if isOpen then
			TweenService:Create(arrowIcon, tInfo, {Rotation = 0, ImageColor3 = KazeUI.GlowColor}):Play()
			TweenService:Create(accentLine, tInfo, {BackgroundColor3 = KazeUI.GlowColor}):Play()
