		if type(arg1) == "table" then title, min, max, def, callback, flag = arg1.Title, arg1.Min, arg1.Max, arg1.Default, arg1.Callback, arg1.Flag
		else title, min, max, def, callback, flag = arg1, arg2, arg3, arg4, arg5, arg6 end
		local el = CreateSliderInput(target, title, min, max, def, callback, flag, isGrouped)
		apiTable:SetGroupedElement(el)
		return el
