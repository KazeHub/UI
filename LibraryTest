-- 27. Command Palette Quick Command Overlay (Ctrl + K Trigger style)
function KazeUI:CreateCommandPalette(winInstance, config)
	config = config or {}
	local commands = config.Commands or {"/rejoin", "/clear-configs", "/reset-theme", "/toggle-window"}
	local callback = config.Callback

	local paletteBg = Instance.new("Frame", ScreenGui)
	paletteBg.Size = UDim2.fromScale(1, 1)
	paletteBg.BackgroundTransparency = 1
	paletteBg.ZIndex = 900
	paletteBg.Visible = false

	local panel = Instance.new("Frame", paletteBg)
	panel.Size = UDim2.fromOffset(300, 240)
	panel.AnchorPoint = Vector2.new(0.5, 0.5)
	panel.Position = UDim2.fromScale(0.5, 0.4)
	Instance.new("UICorner", panel).CornerRadius = UDim.new(0, 10)
	panel.BackgroundColor3 = Color3.fromRGB(13, 13, 15)

	local stroke = Instance.new("UIStroke", panel)
	stroke.Color = KazeUI.GlowColor

	local search = Instance.new("TextBox", panel)
	search.Size = UDim2.new(1, -24, 0, 32)
	search.Position = UDim2.fromOffset(12, 12)
	search.PlaceholderText = "Search command palette..."
	search.Font = Enum.Font.Gotham
	search.TextSize = 11
	search.TextColor3 = Color3.fromRGB(240, 240, 245)
	search.TextXAlignment = Enum.TextXAlignment.Left
	Instance.new("UICorner", search).CornerRadius = UDim.new(0, 6)
	search.BackgroundColor3 = Color3.fromRGB(20, 20, 22)

	local listArea = Instance.new("ScrollingFrame", panel)
	listArea.Size = UDim2.new(1, -24, 1, -64)
	listArea.Position = UDim2.fromOffset(12, 52)
	listArea.BackgroundTransparency = 1
	listArea.BorderSizePixel = 0
	listArea.ScrollBarThickness = 2

	local listLayout = Instance.new("UIListLayout", listArea)
	listLayout.Padding = UDim.new(0, 4)

	local function renderItems(searchQuery)
		for _, v in ipairs(listArea:GetChildren()) do
			if v:IsA("GuiObject") then v:Destroy() end
		end
		for _, cmd in ipairs(commands) do
			if searchQuery == "" or string.find(string.lower(cmd), string.lower(searchQuery), 1, true) then
				local btn = Instance.new("TextButton", listArea)
				btn.Size = UDim2.new(1, 0, 0, 24)
				btn.Text = "  " .. cmd
				btn.Font = Enum.Font.GothamMedium
				btn.TextSize = 11
				btn.TextColor3 = Color3.fromRGB(140, 140, 150)
				btn.TextXAlignment = Enum.TextXAlignment.Left
				Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
				btn.BackgroundColor3 = Color3.fromRGB(17, 17, 19)

				btn.MouseEnter:Connect(function()
					btn.TextColor3 = Color3.fromRGB(255, 255, 255)
					btn.BackgroundColor3 = KazeUI.GlowColor
				end)
				btn.MouseLeave:Connect(function()
					btn.TextColor3 = Color3.fromRGB(140, 140, 150)
					btn.BackgroundColor3 = Color3.fromRGB(17, 17, 19)
				end)
				btn.MouseButton1Click:Connect(function()
					paletteBg.Visible = false
					if type(callback) == "function" then task.spawn(callback, cmd) end
				end)
			end
		end
	end

	renderItems("")
	search:GetPropertyChangedSignal("Text"):Connect(function()
		renderItems(search.Text)
	end)

	UIS.InputBegan:Connect(function(input, gp)
		if not gp and input.KeyCode == Enum.KeyCode.K and UIS:IsKeyDown(Enum.KeyCode.LeftControl) then
			paletteBg.Visible = not paletteBg.Visible
			if paletteBg.Visible then
				search:CaptureFocus()
			end
		end
	end)

	return paletteBg
end

return KazeUI
