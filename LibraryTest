		selectedSingle = defaultOption or (options[1] or "")
	end

	local wrapper = Instance.new("Frame")
	wrapper.Name = "DropdownWrapper"
	wrapper.Size = UDim2.new(1, 0, 0, 0)
	wrapper.BackgroundTransparency = 1
	wrapper.Parent = parentFrame
