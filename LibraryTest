		return el
	end

	function apiTable:Toggle(arg1, arg2, arg3, arg4, arg5)
		local target, isGrouped = getTarget()
		local title, desc, def, callback, flag
		if type(arg1) == "table" then title, desc, def, callback, flag = arg1.Title, (arg1.Description or arg1.Content or ""), arg1.Default, arg1.Callback, arg1.Flag
		else title, desc, def, callback, flag = arg1, arg2, arg3, arg4, arg5 end
		local el = CreateToggleSwitch(target, title, desc, def, callback, flag, isGrouped)
		apiTable:SetGroupedElement(el)
		return el
	end

	function apiTable:TextBox(arg1, arg2, arg3, arg4, arg5)
		local target, isGrouped = getTarget()
		local title, place, def, callback, flag
		if type(arg1) == "table" then title, place, def, callback, flag = arg1.Title, arg1.Placeholder, arg1.Default, arg1.Callback, arg1.Flag
		else title, place, def, callback, flag = arg1, arg2, arg3, arg4, arg5 end
		local el = CreateTextBoxInput(target, title, place, def, callback, flag, isGrouped)
