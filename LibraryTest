AttachElementsToAPI = function(apiTable, parentFrame)
	
	local function getTarget()
		return apiTable.CurrentGroup or parentFrame, apiTable.CurrentGroup ~= nil
	end
	
	function apiTable:SetGroupedElement(elementData)
		if self.CurrentGroup then
			if self.LastGroupElement and self.LastGroupElement.BottomLine then
				self.LastGroupElement.BottomLine.Visible = true
			end
			self.LastGroupElement = elementData
			if elementData.BottomLine then
				elementData.BottomLine.Visible = false
			end
		end
	end

	function apiTable:Divider()
		local wrapper = Instance.new("Frame")
		wrapper.Size = UDim2.new(1, 0, 0, 0)
		wrapper.AutomaticSize = Enum.AutomaticSize.Y
		wrapper.BackgroundTransparency = 1
		wrapper.Parent = parentFrame
		
		local padding = Instance.new("UIPadding", wrapper)
		padding.PaddingTop = UDim.new(0, 4)
		padding.PaddingBottom = UDim.new(0, 4)

		local groupCard = Instance.new("Frame")
		groupCard.Name = "GroupCard"
		groupCard.Size = UDim2.new(0.95, 0, 0, 0)
		groupCard.AutomaticSize = Enum.AutomaticSize.Y
		groupCard.AnchorPoint = Vector2.new(0.5, 0)
		groupCard.Position = UDim2.new(0.5, 0, 0, 0)
		groupCard.BackgroundTransparency = 1
		groupCard.ClipsDescendants = true
		groupCard.Parent = wrapper
		Instance.new("UICorner", groupCard).CornerRadius = UDim.new(0, 8)
		
		local groupStroke = Instance.new("UIStroke", groupCard)
		groupStroke.Thickness = 1.2
		groupStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
		KazeUI:RegisterBorder(groupStroke)
		
		local layout = Instance.new("UIListLayout", groupCard)
		layout.SortOrder = Enum.SortOrder.LayoutOrder
		layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
		
		self.CurrentGroup = groupCard
		self.LastGroupElement = nil
		return groupCard
	end

	function apiTable:AddLabel(arg1)
		local target, isGrouped = getTarget()
		local t = type(arg1) == "table" and (arg1.Text or arg1.Title) or arg1
		
		local wrapper = Instance.new("Frame")
		wrapper.Size = UDim2.new(isGrouped and 1 or 0.95, 0, 0, 24)
		wrapper.BackgroundTransparency = 1
		wrapper.Parent = target
		if not isGrouped then
			wrapper.AnchorPoint = Vector2.new(0.5, 0)
			wrapper.Position = UDim2.new(0.5, 0, 0, 3)
		end

		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1, -20, 1, 0)
		label.Position = UDim2.fromOffset(10, 0)
		label.BackgroundTransparency = 1
		label.Text = tostring(t or " ")
		label.Font = Enum.Font.Gotham
		label.TextSize = 12
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.TextWrapped = true
		label.Parent = wrapper
		KazeUI:RegisterText(label, true)
		
		local bottomLine = AddBottomLine(wrapper, isGrouped)
		apiTable:SetGroupedElement({ Label = label, BottomLine = bottomLine })
		return label
	end

	function apiTable:Paragraph(arg1, arg2)
		local target, isGrouped = getTarget()
		local title = type(arg1) == "table" and arg1.Title or arg1
		local content = type(arg1) == "table" and (arg1.Content or arg1.Description) or arg2
		local el = CreateParagraph(target, title, content, isGrouped)
		apiTable:SetGroupedElement(el)
		return el
	end

	function apiTable:Button(arg1, arg2, arg3)
