	if isGrouped then
		paraFrame.Size = UDim2.new(1, 0, 0, totalHeight)
		paraFrame.Position = UDim2.new(0.5, 0, 0, 0)
		KazeUI:AddPanel(paraFrame, 0.02)
	else
