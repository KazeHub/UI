		titLab.Font = Enum.Font.Gotham
		titLab.TextSize = 10
		KazeUI:RegisterText(titLab, true)

		return {
			Update = function(newVal) valLab.Text = newVal end
		}
	end

	local fpsMetric = addMetric("FPS", "60")
	local pingMetric = addMetric("PING", "32ms")
	local memMetric = addMetric("MEM", "450MB")
	local execMetric = addMetric("EXEC", "Kaze v3")

	-- Spawn thread to dynamically simulate updates
