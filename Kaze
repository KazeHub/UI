		setToggleState(not state, false)
		if typeof(callback) == "function" then
			task.spawn(callback, state)
		end
	end)
	
	return {
		Wrapper = wrapper,
		Frame = paraFrame,
		SetState = function(self, newState, instant)
			setToggleState(newState, instant)
		end,
		GetState = function(self)
			return state
		end
	}
end

