		local track = Instance.new("Frame", pickerArea)
		track.Size = UDim2.new(1, -50, 0, 6); track.Position = UDim2.new(0, 30, 0, yPos + 7)
		track.BackgroundColor3 = Color3.fromRGB(16,16,20); Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)
		
		local fill = Instance.new("Frame", track)
		fill.Size = UDim2.new(0, 0, 1, 0); fill.BackgroundColor3 = col; Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)
		
		local btn = Instance.new("TextButton", track)
		btn.Size = UDim2.new(1, 0, 1, 14); btn.Position = UDim2.new(0, 0, 0, -7); btn.BackgroundTransparency = 1; btn.Text = ""
		
		return {track = track, fill = fill, btn = btn}
	end
	
	local rSlider = createRGB("R", 10, Color3.fromRGB(255, 80, 80))
	local gSlider = createRGB("G", 40, Color3.fromRGB(80, 255, 80))
	local bSlider = createRGB("B", 70, Color3.fromRGB(80, 80, 255))
	
	local function updateColor()
		colorPreview.BackgroundColor3 = color
		rSlider.fill.Size = UDim2.new(color.R, 0, 1, 0)
		gSlider.fill.Size = UDim2.new(color.G, 0, 1, 0)
		bSlider.fill.Size = UDim2.new(color.B, 0, 1, 0)
		if typeof(callback) == "function" then task.spawn(callback, color) end
	end
	
	local function bindSlider(obj, component)
		local dragging = false
		obj.btn.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = true; ToggleScrollingAncestors(cFrame, false)
				local perc = math.clamp((input.Position.X - obj.track.AbsolutePosition.X)/obj.track.AbsoluteSize.X, 0, 1)
				if component == "R" then color = Color3.new(perc, color.G, color.B)
				elseif component == "G" then color = Color3.new(color.R, perc, color.B)
				else color = Color3.new(color.R, color.G, perc) end
				updateColor()
			end
		end)
		UIS.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
				dragging = false; ToggleScrollingAncestors(cFrame, true)
			end
		end)
		UIS.InputChanged:Connect(function(input)
			if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
				local perc = math.clamp((input.Position.X - obj.track.AbsolutePosition.X)/obj.track.AbsoluteSize.X, 0, 1)
				if component == "R" then color = Color3.new(perc, color.G, color.B)
				elseif component == "G" then color = Color3.new(color.R, perc, color.B)
				else color = Color3.new(color.R, color.G, perc) end
				updateColor()
			end
		end)
	end
	
	bindSlider(rSlider, "R"); bindSlider(gSlider, "G"); bindSlider(bSlider, "B")
	updateColor()
	
	click.MouseButton1Click:Connect(function() isOpen = not isOpen; pickerArea.Visible = isOpen end)
	
	local api = {
		GetValue = function() return {color.R*255, color.G*255, color.B*255} end,
		SetValue = function(self, val)
			if type(val) == "table" then color = Color3.fromRGB(val[1], val[2], val[3]) end
			updateColor()
		end
	}
	KazeUI.Elements[title] = api
	return api
end

