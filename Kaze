			end
			TweenService:Create(btn, TweenInfo.new(0.12), { BackgroundColor3 = KazeUI.GetColor(0.06) }):Play()
			leftIndicator.Visible = true
			page.Visible = true
			txt.TextColor3 = Color3.fromRGB(255, 255, 255)
			txt.Font = Enum.Font.GothamBold
		end

		btn.MouseEnter:Connect(function()
			if not leftIndicator.Visible then
				TweenService:Create(btn, TweenInfo.new(0.1), { BackgroundColor3 = KazeUI.GetColor(0.04) }):Play()
				txt.TextColor3 = Color3.fromRGB(220, 220, 220)
			end
		end)
		btn.MouseLeave:Connect(function()
			if not leftIndicator.Visible then
				TweenService:Create(btn, TweenInfo.new(0.1), { BackgroundColor3 = KazeUI.GetColor(0.02) }):Play()
				txt.TextColor3 = Color3.fromRGB(200, 200, 200)
			end
		end)
		btn.MouseButton1Click:Connect(activate)
		if #self._Tabs == 1 then activate() end

		local public = { Button = btn, Page = page }
		AttachElementsToAPI(public, pageContent)
		function public:SetText(newText)
			txt.Text = newText
		end
		return public
	end

