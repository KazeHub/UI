	Avatar.BackgroundColor3 = Color3.fromRGB(30,30,35); Avatar.Image = MainIcon
	Instance.new("UICorner", Avatar).CornerRadius = UDim.new(1,0)
	local AvatarStroke = Instance.new("UIStroke", Avatar)
	AvatarStroke.Thickness = 1; ApplyTheme(AvatarStroke, "Color")

	local TitleLabel = Instance.new("TextLabel", TopBar)
	TitleLabel.Size = UDim2.new(1, -200, 0, 20); TitleLabel.Position = UDim2.fromOffset(50,6)
	TitleLabel.BackgroundTransparency = 1; TitleLabel.Text = Title; TitleLabel.TextColor3 = Color3.fromRGB(235,235,235)
	TitleLabel.Font = Enum.Font.GothamBold; TitleLabel.TextSize = 15; TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

	local SubLabel = Instance.new("TextLabel", TopBar)
	SubLabel.Size = UDim2.new(1, -200, 0, 16); SubLabel.Position = UDim2.fromOffset(50,26)
	SubLabel.BackgroundTransparency = 1; SubLabel.Text = Author .. " | v" .. Version; SubLabel.TextColor3 = Color3.fromRGB(160,160,160)
	SubLabel.Font = Enum.Font.Gotham; SubLabel.TextSize = 12; SubLabel.TextXAlignment = Enum.TextXAlignment.Left

	local TopDivider = Instance.new("Frame", TopBar)
	TopDivider.Size = UDim2.new(1,0,0,2); TopDivider.Position = UDim2.new(0,0,1,-2); TopDivider.BorderSizePixel = 0
	ApplyTheme(TopDivider, "BackgroundColor3")

	local function cBtn(name, offX, col)
		local b = Instance.new("TextButton", TopBar)
		b.Size = UDim2.fromOffset(16,16); b.Position = UDim2.new(1, offX, 0.5, -8); b.BackgroundColor3 = col; b.Text = ""
		Instance.new("UICorner", b).CornerRadius = UDim.new(1,0); return b
	end
	local BtnGreen = cBtn("BtnG", -96, Color3.fromRGB(117,204,50))
	local BtnYellow = cBtn("BtnY", -68, Color3.fromRGB(255,204,51))
	local BtnRed = cBtn("BtnR", -40, Color3.fromRGB(235,80,80))

	BtnYellow.MouseButton1Click:Connect(function() Window.Visible = false end)
	UIS.InputBegan:Connect(function(inp, gpe) if not gpe and inp.KeyCode == Enum.KeyCode.RightShift then Window.Visible = not Window.Visible end end)
	BtnRed.MouseButton1Click:Connect(function() ScreenGui:Destroy(); NotificationGui:Destroy() end)

	local Content = Instance.new("Frame", Window)
	Content.Position = UDim2.fromOffset(0,50); Content.Size = UDim2.new(1,0,1,-50); Content.BackgroundTransparency = 1

	local SideBar = Instance.new("Frame", Content)
	SideBar.Size = UDim2.new(0,150,1,0); SideBar.BackgroundColor3 = Color3.fromRGB(20,20,25)
	Instance.new("UICorner", SideBar).CornerRadius = UDim.new(0,12)

	local VertDivider = Instance.new("Frame", Content)
	VertDivider.Size = UDim2.new(0,2,1,0); VertDivider.Position = UDim2.new(0,150,0,0); VertDivider.BorderSizePixel = 0
	ApplyTheme(VertDivider, "BackgroundColor3")

	local Pages = Instance.new("Frame", Content)
	Pages.Position = UDim2.new(0,152,0,0); Pages.Size = UDim2.new(1, -152, 1, 0); Pages.BackgroundColor3 = Color3.fromRGB(18,18,23)
	Instance.new("UICorner", Pages).CornerRadius = UDim.new(0,12)

	local TabsScroller = Instance.new("ScrollingFrame", SideBar)
	TabsScroller.Position = UDim2.fromOffset(6,6); TabsScroller.Size = UDim2.new(1, -12, 1, -12)
	TabsScroller.BackgroundTransparency = 1; TabsScroller.ScrollBarThickness = 2; TabsScroller.AutomaticCanvasSize = Enum.AutomaticSize.Y

	local TabsList = Instance.new("Frame", TabsScroller)
	TabsList.Size = UDim2.new(1, 0, 0, 0); TabsList.BackgroundTransparency = 1; TabsList.AutomaticSize = Enum.AutomaticSize.Y
	local tabsLayout = Instance.new("UIListLayout", TabsList)
	tabsLayout.SortOrder = Enum.SortOrder.LayoutOrder; tabsLayout.Padding = UDim.new(0,4)

	local createdTabs = {}
	local Win = { Window = Window, _Pages = Pages, _TabsList = TabsList, _Tabs = createdTabs }

	function Win:CreateTab(name, iconId)
		local btn = Instance.new("TextButton", TabsList)
		btn.Size = UDim2.new(1, -8, 0, 36); btn.BackgroundColor3 = Color3.fromRGB(24,24,28); btn.Text = ""
		btn.LayoutOrder = #self._Tabs + 1
		Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

		local indicator = Instance.new("Frame", btn)
		indicator.Size = UDim2.new(0, 3, 1, 0); indicator.Visible = false
		Instance.new("UICorner", indicator).CornerRadius = UDim.new(0,6); ApplyTheme(indicator, "BackgroundColor3")

		local iconLabel = Instance.new("ImageLabel", btn)
		iconLabel.Size = UDim2.fromOffset(20,20); iconLabel.Position = UDim2.new(0, 8, 0.5, -10)
		iconLabel.BackgroundTransparency = 1
		-- Uses Auto Icon fallback if empty!
		iconLabel.Image = FormatImage(iconId, "rbxassetid://4370318685") 
		
		local txt = Instance.new("TextLabel", btn)
		txt.Size = UDim2.new(1, -36, 1, 0); txt.Position = UDim2.fromOffset(36, 0)
		txt.BackgroundTransparency = 1; txt.Text = name; txt.TextColor3 = Color3.fromRGB(200,200,200)
		txt.Font = Enum.Font.Gotham; txt.TextSize = 13; txt.TextXAlignment = Enum.TextXAlignment.Left

		local page = Instance.new("Frame", self._Pages)
		page.Size = UDim2.new(1,0,1,0); page.BackgroundTransparency = 1; page.Visible = false

		local pageContent = Instance.new("ScrollingFrame", page)
		pageContent.Size = UDim2.new(1, 0, 1, 0); pageContent.BackgroundTransparency = 1; pageContent.ScrollBarThickness = 4
		pageContent.AutomaticCanvasSize = Enum.AutomaticSize.Y

		local pPad = Instance.new("UIPadding", pageContent)
		pPad.PaddingTop = UDim.new(0,8); pPad.PaddingBottom = UDim.new(0,8)
		local pLay = Instance.new("UIListLayout", pageContent)
		pLay.SortOrder = Enum.SortOrder.LayoutOrder; pLay.Padding = UDim.new(0, 6); pLay.HorizontalAlignment = Enum.HorizontalAlignment.Center

		local tabObj = { Button = btn, Indicator = indicator, Label = txt, Page = page }
		table.insert(self._Tabs, tabObj)

		local function activate()
			for _, t in ipairs(self._Tabs) do
				t.Indicator.Visible = false; t.Page.Visible = false
				TweenService:Create(t.Button, TweenInfo.new(0.12), {BackgroundColor3 = Color3.fromRGB(24,24,28)}):Play()
				t.Label.TextColor3 = Color3.fromRGB(200,200,200); t.Label.Font = Enum.Font.Gotham
			end
			indicator.Visible = true; page.Visible = true
			TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = Color3.fromRGB(32,32,36)}):Play()
			txt.TextColor3 = Color3.fromRGB(255,255,255); txt.Font = Enum.Font.GothamBold
		end

		btn.MouseButton1Click:Connect(activate)
		if #self._Tabs == 1 then activate() end

		local public = {}
		
		function public:Label(text) return CreateLabel(pageContent, text) end
		function public:Paragraph(t, b) return CreateParagraph(pageContent, t, b) end
		function public:Button(t, b, cb) return CreateButton(pageContent, t, b, cb) end
		function public:Toggle(t, b, d, cb) return CreateToggle(pageContent, t, b, d, cb) end
		function public:TextBox(t, p, cb) return CreateTextBox(pageContent, t, p, cb) end
		function public:Keybind(t, d, cb) return CreateKeybind(pageContent, t, d, cb) end
		function public:ColorPicker(t, d, cb) return CreateColorPicker(pageContent, t, d, cb) end
		function public:Divider(t) return CreateDivider(pageContent, t) end
		function public:SearchBar() return CreateSearchBar(pageContent, pageContent) end

		function public:SectionUI(title) return CreateCollapsibleSection(pageContent, title) end

		-- SMART COMPONENT PARSERS --
		function public:Dropdown(t, opt, d, arg4, arg5) return CreateDropdown(pageContent, t, opt, d, arg4, arg5) end
		function public:Slider(t, min, max, d, arg5, arg6) return CreateSlider(pageContent, t, min, max, d, arg5, arg6) end

		public.AddLabel = public.Label; public.AddParagraph = public.Paragraph; public.AddButton = public.Button; public.AddToggle = public.Toggle
		public.AddSlider = public.Slider; public.AddTextBox = public.TextBox; public.Textbox = public.TextBox; public.AddDropdown = public.Dropdown
		public.AddKeybind = public.Keybind; public.AddColorPicker = public.ColorPicker; public.AddDivider = public.Divider
		public.AddSearchBar = public.SearchBar

		return public
	end

	if typeof(Callback) == "function" then task.spawn(Callback) end
	return Win
end

return KazeUI
