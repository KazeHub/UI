end

function KazeUI:SetTheme(color)
	self.ThemeColor = color
	for _, item in ipairs(self.ThemeInstances) do
		if item.Instance and item.Instance.Parent then
			TweenService:Create(item.Instance, TweenInfo.new(0.3), {[item.Property] = color}):Play()
		end
	end
end

KazeUI.ThemeManager = { SetTheme = function(color) KazeUI:SetTheme(color) end }

KazeUI.ConfigManager = {
	FolderName = "KazeUI_Configs",
	Save = function(filename)
		if not isfolder(KazeUI.ConfigManager.FolderName) then makefolder(KazeUI.ConfigManager.FolderName) end
		local data = {}
		for key, api in pairs(KazeUI.Elements) do if api.GetValue then data[key] = api:GetValue() end end
		writefile(KazeUI.ConfigManager.FolderName.."/"..filename..".json", HttpService:JSONEncode(data))
		KazeUI:Notify({Title = "Config Saved", Content = "Saved " .. filename, Duration = 2})
	end,
	Load = function(filename)
		local path = KazeUI.ConfigManager.FolderName.."/"..filename..".json"
		if isfile(path) then
			local success, result = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
			if success then
				for key, val in pairs(result) do if KazeUI.Elements[key] and KazeUI.Elements[key].SetValue then KazeUI.Elements[key]:SetValue(val) end end
				KazeUI:Notify({Title = "Config Loaded", Content = "Loaded " .. filename, Duration = 2})
			end
		else
			KazeUI:Notify({Title = "Error", Content = "Config not found!", Duration = 2})
		end
	end
}

