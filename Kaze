		Overlay.Parent = Window

		PlayTween(Overlay, TWEENS.Fast, {BackgroundTransparency = 0.65})

		local ConfirmWindow = Instance.new("Frame")
		ConfirmWindow.Size, ConfirmWindow.AnchorPoint, ConfirmWindow.Position, ConfirmWindow.ZIndex = UDim2.fromOffset(340, 140), Vector2.new(0.5,0.5), UDim2.fromScale(0.5,0.45), 52
		Instance.new("UICorner", ConfirmWindow).CornerRadius = UDim.new(0,10)
