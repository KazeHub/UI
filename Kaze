	divider.Parent = dropFrame

	local listContainer = Instance.new("ScrollingFrame")
	listContainer.Size, listContainer.BackgroundTransparency, listContainer.BorderSizePixel = UDim2.new(1, -16, 0, 0), 1, 0
	listContainer.LayoutOrder, listContainer.Visible = 4, false
	listContainer.ScrollBarThickness, listContainer.ScrollBarImageColor3 = 3, Color3.fromRGB(60, 60, 65)
	listContainer.Parent = dropFrame

	listContainer.MouseEnter:Connect(function() ToggleScrollingAncestors(dropFrame, false) end)
	listContainer.MouseLeave:Connect(function() ToggleScrollingAncestors(dropFrame, true) end)

	local listLayout = Instance.new("UIListLayout", listContainer)
	listLayout.SortOrder, listLayout.Padding = Enum.SortOrder.LayoutOrder, UDim.new(0, 3)

	local optionItems = {}

	local function CalcHeight()
		local count = 0
		for _, item in ipairs(optionItems) do if item.Btn.Visible then count = count + 1 end end
		PlayTween(listContainer, TWEENS.Smooth, {Size = UDim2.new(1, -16, 0, math.min(count, 5) * 32)})
		listContainer.CanvasSize = UDim2.new(0, 0, 0, count * 32)
	end

	local function CloseDropdown()
		isOpen = false
		searchBox.Text = "" 
		searchWrapper.Visible, divider.Visible, listContainer.Visible = false, false, false
		PlayTween(arrowIcon, TWEENS.Spring, {Rotation = 0})
		PlayTween(boxStroke, TWEENS.Fast, {Color = KazeUI.CurrentTheme.Border})
	end

	local function Refresh(newOptions)
		for _, item in ipairs(optionItems) do item.Btn:Destroy() end
		table.clear(optionItems)

		options = type(newOptions) == "table" and newOptions or {}
		for _, opt in ipairs(options) do
			local optStr = tostring(opt)
			local btn = Instance.new("TextButton")
			btn.Size, btn.BorderSizePixel, btn.Text = UDim2.new(1, -4, 0, 30), 0, "  " .. optStr
			btn.Font, btn.TextSize, btn.TextXAlignment = Enum.Font.Gotham, 12, Enum.TextXAlignment.Left
			Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
			KazeUI:AddPanel(btn, 0.03, true)
			btn.Parent = listContainer

			local indicator
			if isMulti then
				indicator = Instance.new("Frame")
				indicator.AnchorPoint, indicator.Position, indicator.Size = Vector2.new(1, 0.5), UDim2.new(1, -8, 0.5, 0), UDim2.fromOffset(12, 12)
				KazeUI:RegisterBorder(Instance.new("UIStroke", indicator))
				Instance.new("UICorner", indicator).CornerRadius = UDim.new(0, 4)
				KazeUI:AddPanel(indicator, 0.04)
				indicator.Parent = btn
			end
            
			local isHovering = false
			local function UpdateVisuals(instant)
				local active = isMulti and selectedMulti[optStr] or (not isMulti and selectedSingle == optStr)
				local targetBg = active and KazeUI.GetColor(0.06) or KazeUI.GetColor(0.03)
				local targetTxt = active and KazeUI.CurrentTheme.Text or KazeUI.CurrentTheme.MutedText
				local indTargetBg = active and KazeUI.GlowColor or KazeUI.GetColor(0.03)
				
				if isHovering then
					targetBg, targetTxt = KazeUI.GetColor(0.08), KazeUI.CurrentTheme.Text
				end

				if instant then
					btn.BackgroundColor3, btn.TextColor3 = targetBg, targetTxt
					if indicator then indicator.BackgroundColor3 = indTargetBg end
				else
					PlayTween(btn, TWEENS.Fast, {BackgroundColor3 = targetBg, TextColor3 = targetTxt})
					if indicator then PlayTween(indicator, TWEENS.Fast, {BackgroundColor3 = indTargetBg}) end
				end
			end
			UpdateVisuals(true)

			btn.MouseEnter:Connect(function() isHovering = true; UpdateVisuals(false) end)
			btn.MouseLeave:Connect(function() isHovering = false; UpdateVisuals(false) end)

			btn.MouseButton1Down:Connect(function()
				PlayTween(btn, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(1, -8, 0, 28)})
			end)
			
			btn.MouseButton1Up:Connect(function()
				PlayTween(btn, TWEENS.Spring, {Size = UDim2.new(1, -4, 0, 30)})
				if isMulti then
					selectedMulti[optStr] = not selectedMulti[optStr]
					UpdateVisuals(false)
					UpdateHeaderVisual()
					if type(callback) == "function" then
						local ret = {}
						for k,v in pairs(selectedMulti) do if v then table.insert(ret, k) end end
						task.spawn(callback, ret)
					end
				else
					selectedSingle = optStr
					UpdateHeaderVisual()
					CloseDropdown()
					for _, item in ipairs(optionItems) do item.Update(false) end
					if type(callback) == "function" then task.spawn(callback, selectedSingle) end
				end
			end)

			table.insert(optionItems, { Btn = btn, Text = optStr, Update = function(instant) UpdateVisuals(instant) end })
			KazeUI:OnGlowChanged(btn, function() UpdateVisuals(true) end)
		end
		CalcHeight()
	end

	Refresh(options)

	searchBox:GetPropertyChangedSignal("Text"):Connect(function()
		local q = string.lower(searchBox.Text)
		for _, item in ipairs(optionItems) do
			item.Btn.Visible = (q == "" or string.find(string.lower(item.Text), q, 1, true)) ~= nil
		end
		CalcHeight()
	end)

	clickBtn.MouseButton1Click:Connect(function()
		isOpen = not isOpen
		if isOpen then
			searchWrapper.Visible, divider.Visible, listContainer.Visible = true, true, true
			CalcHeight()
			PlayTween(arrowIcon, TWEENS.Spring, {Rotation = 180})
			PlayTween(boxStroke, TWEENS.Fast, {Color = KazeUI.GlowColor})
		else CloseDropdown() end
	end)
	
	KazeUI:OnGlowChanged(boxStroke, function(c) if isOpen then boxStroke.Color = c end end)
	KazeUI:OnGlowChanged(searchStroke, function(c) if searchBox:IsFocused() then searchStroke.Color = c end end)
	KazeUI:OnThemeChanged(dropFrame, function() for _, item in ipairs(optionItems) do item.Update(true) end end)

	RegisterFlag(flag, function()
		if isMulti then
			local ret = {}
			for k,v in pairs(selectedMulti) do if v then table.insert(ret, k) end end
			return ret
		end
		return selectedSingle 
	end, function(val)
		if isMulti then 
			selectedMulti = {}
			if type(val) == "table" then for _, v in ipairs(val) do selectedMulti[tostring(v)] = true end end
		else selectedSingle = tostring(val) end
		UpdateHeaderVisual()
		Refresh(options)
		if typeof(callback) == "function" then
			if isMulti then
				local ret = {}
				for k,v in pairs(selectedMulti) do if v then table.insert(ret, k) end end
				task.spawn(callback, ret)
			else task.spawn(callback, selectedSingle) end
		end
	end)

	wrapper.Parent = parentFrame
	return {
		Wrapper = wrapper,
		Frame = dropFrame,
		Refresh = function(self, newOpts) Refresh(newOpts) end,
		GetValue = function() 
			if isMulti then
				local ret = {}
				for k,v in pairs(selectedMulti) do if v then table.insert(ret, k) end end
				return ret
			end
			return selectedSingle 
		end,
		SetText = function(self, newTitle) titleLabel.Text = newTitle end
	}
end

