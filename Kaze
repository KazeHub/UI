			check.Size = UDim2.new(0, 20, 1, 0); check.Position = UDim2.new(1, -24, 0, 0); check.BackgroundTransparency = 1
			check.Text = "✓"; check.TextColor3 = KazeUI.ThemeColor; check.Font = Enum.Font.GothamBold; check.TextSize = 14; check.Visible = false
			ApplyTheme(check, "TextColor3")
			
			local function updateVisual()
				local isActive = false
				if isMulti then
					isActive = table.find(selected, optStr) ~= nil
				else
					isActive = (selected == optStr)
				end
				btn.TextColor3 = isActive and KazeUI.ThemeColor or Color3.fromRGB(200, 200, 200)
				check.Visible = isActive
			end
			updateVisual()
			
			btn.MouseButton1Click:Connect(function()
				if isMulti then
					local idx = table.find(selected, optStr)
					if idx then table.remove(selected, idx) else table.insert(selected, optStr) end
					selectedLabel.Text = table.concat(selected, ", ")
					if selectedLabel.Text == "" then selectedLabel.Text = "None" end
				else
					selected = optStr; selectedLabel.Text = selected; click.MouseButton1Click:Fire() 
				end
				for _, other in ipairs(optionItems) do other.update() end
				if typeof(callback) == "function" then task.spawn(callback, selected) end
			end)
			
			table.insert(optionItems, {btn = btn, update = updateVisual})
		end
		local height = math.min(#options * 30 + 8, 120)
		listContainer.Size = UDim2.new(1, 0, 0, height)
	end
	
	Refresh(options)
	
	click.MouseButton1Click:Connect(function()
		isOpen = not isOpen; listContainer.Visible = isOpen
		TweenService:Create(arrow, TweenInfo.new(0.2), {Rotation = isOpen and 180 or 0}):Play()
	end)
	
	local api = {
		GetValue = function() return selected end,
		SetValue = function(self, val)
			selected = val
			selectedLabel.Text = isMulti and table.concat(selected, ", ") or tostring(selected)
			if selectedLabel.Text == "" and isMulti then selectedLabel.Text = "None" end
			for _, item in ipairs(optionItems) do item.update() end
			if typeof(callback) == "function" then task.spawn(callback, selected) end
		end,
		Refresh = function(self, newOpts) Refresh(newOpts) end
	}
