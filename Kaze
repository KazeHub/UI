-- Awtomatikong pag-scale base sa laki ng screen
local function UpdateScale()
	local size = workspace.CurrentCamera.ViewportSize
	local scaleX = math.clamp(size.X / 800, 0.35, 1)
	local scaleY = math.clamp(size.Y / 500, 0.35, 1)
	UIScale.Scale = math.min(scaleX, scaleY)
	ScreenGui.IgnoreGuiInset = true
end

UpdateScale()
workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(UpdateScale)

-- Image Formatter Helper
local function FormatImage(id)
	if not id then return "" end
	id = tostring(id)
	local clean = string.gsub(id, "%D", "")
	if clean == "" then return "" end
	return "rbxassetid://" .. clean
end

-- Draggable UI Logic
local function MakeDraggable(dragPart, targetPart)
	local dragging = false
	local dragInput, dragStart, startPos
	local function update(input)
		if not dragStart or not startPos then return end
		local delta = input.Position - dragStart
		targetPart.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end
	dragPart.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = targetPart.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
					dragInput = nil
				end
			end)
		end
	end)
	dragPart.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)
	UIS.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			update(input)
		end
	end)
end

-- Neon glow effect loop
local function StartNeonLoop(target)
	if not target then return end
	task.spawn(function()
		local propName
		if pcall(function() return target.Color end) then
			propName = "Color"
		elseif pcall(function() return target.BackgroundColor3 end) then
			propName = "BackgroundColor3"
		end
		if not propName then return end
		
		local tweenInfo = TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
		local ok, tween = pcall(function()
			return TweenService:Create(target, tweenInfo, { [propName] = Color3.fromRGB(0, 255, 255) })
		end)
		if ok and tween then 
			tween:Play() 
		end
	end)
end

-- Helper: Temporarily disables parent ScrollingFrames so sliding isn't interrupted on Mobile
local function ToggleScrollingAncestors(element, state)
	local current = element.Parent
	while current do
		if current:IsA("ScrollingFrame") then
			current.ScrollingEnabled = state
		end
		current = current.Parent
	end
end

-- Helper: Gumawa ng Dropdown Selection Row (Premium style + Multi-Select)
local function CreateDropdown(parentFrame, strokeColor, config)
	config = type(config) == "table" and config or {Title = tostring(config)}
	local title = tostring(config.Title or "Dropdown")
	local options = config.Values or config.Options or {}
	local multi = config.Multi or false
	local callback = config.Callback

	local selected
	if multi then
		selected = {}
		if type(config.Default) == "table" then
			for _, v in ipairs(config.Default) do
				table.insert(selected, tostring(v))
			end
		elseif config.Default then
			table.insert(selected, tostring(config.Default))
		end
	else
		selected = tostring(config.Default or (options[1] or ""))
	end

	local isOpen = false

	local wrapper = Instance.new("Frame")
	wrapper.Name = "DropdownWrapper"
	wrapper.Size = UDim2.new(1, 0, 0, 0)
	wrapper.BackgroundTransparency = 1
	wrapper.Parent = parentFrame
	wrapper.AutomaticSize = Enum.AutomaticSize.Y

	local dropFrame = Instance.new("Frame")
	dropFrame.Name = "DropdownFrame"
	dropFrame.AnchorPoint = Vector2.new(0.5, 0)
	dropFrame.Position = UDim2.new(0.5, 0, 0, 3)
	dropFrame.Size = UDim2.new(0.95, 0, 0, 0)
	dropFrame.BackgroundColor3 = Color3.fromRGB(24, 24, 28)
	dropFrame.BorderSizePixel = 0
	dropFrame.AutomaticSize = Enum.AutomaticSize.Y
	Instance.new("UICorner", dropFrame).CornerRadius = UDim.new(0, 8)
	dropFrame.Parent = wrapper

	local padding = Instance.new("UIPadding", dropFrame)
	padding.PaddingTop = UDim.new(0, 4)
	padding.PaddingBottom = UDim.new(0, 4)

	local boxStroke = Instance.new("UIStroke", dropFrame)
	boxStroke.Thickness = 1.5
	boxStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	boxStroke.Color = strokeColor or Color3.fromRGB(0, 160, 255)
	StartNeonLoop(boxStroke)

	local layout = Instance.new("UIListLayout", dropFrame)
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	layout.Padding = UDim.new(0, 4)

	-- Header Area
	local header = Instance.new("Frame")
	header.Name = "Header"
	header.Size = UDim2.new(1, -16, 0, 36)
	header.BackgroundTransparency = 1
	header.LayoutOrder = 1
	header.Parent = dropFrame

	local titleLabel = Instance.new("TextLabel", header)
	titleLabel.Size = UDim2.new(0.5, 0, 1, 0)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = title
	titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	titleLabel.Font = Enum.Font.GothamBold
	titleLabel.TextSize = 14
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left

	local arrowIcon = Instance.new("ImageLabel", header)
	arrowIcon.AnchorPoint = Vector2.new(1, 0.5)
	arrowIcon.Position = UDim2.new(1, 0, 0.5, 0)
	arrowIcon.Size = UDim2.fromOffset(16, 16)
	arrowIcon.BackgroundTransparency = 1
	arrowIcon.Image = "rbxassetid://6031091004"
	arrowIcon.ImageColor3 = strokeColor or Color3.fromRGB(0, 160, 255)
	arrowIcon.Rotation = 0

	local selectedLabel = Instance.new("TextLabel", header)
	selectedLabel.Size = UDim2.new(0.5, -24, 1, 0)
	selectedLabel.Position = UDim2.new(0.5, 0, 0, 0)
	selectedLabel.BackgroundTransparency = 1
	selectedLabel.Text = ""
	selectedLabel.TextColor3 = strokeColor or Color3.fromRGB(0, 160, 255)
	selectedLabel.Font = Enum.Font.Gotham
	selectedLabel.TextSize = 13
	selectedLabel.TextXAlignment = Enum.TextXAlignment.Right
	selectedLabel.TextTruncate = Enum.TextTruncate.AtEnd

	local function GetSelectedText()
		if multi then
			if #selected == 0 then return "None" end
			return table.concat(selected, ", ")
		end
		return tostring(selected)
	end
	selectedLabel.Text = GetSelectedText()

	local clickBtn = Instance.new("TextButton", header)
	clickBtn.Size = UDim2.fromScale(1, 1)
	clickBtn.BackgroundTransparency = 1
	clickBtn.Text = ""

	-- Divider Line
	local divider = Instance.new("Frame")
	divider.Size = UDim2.new(1, -16, 0, 1)
	divider.BackgroundColor3 = Color3.fromRGB(38, 38, 42)
	divider.BorderSizePixel = 0
	divider.LayoutOrder = 2
	divider.Visible = false
	divider.Parent = dropFrame

	-- Scrollable Options Container
	local listContainer = Instance.new("ScrollingFrame")
	listContainer.Name = "OptionsContainer"
	listContainer.Size = UDim2.new(1, -16, 0, 0)
	listContainer.BackgroundTransparency = 1
	listContainer.BorderSizePixel = 0
	listContainer.LayoutOrder = 3
	listContainer.Visible = false
	listContainer.ScrollBarThickness = 4
	listContainer.ScrollBarImageColor3 = Color3.fromRGB(60, 60, 65)
	listContainer.CanvasSize = UDim2.new(0, 0, 0, 0)
	listContainer.AutomaticCanvasSize = Enum.AutomaticSize.Y
	listContainer.Parent = dropFrame

	listContainer.MouseEnter:Connect(function() ToggleScrollingAncestors(dropFrame, false) end)
	listContainer.MouseLeave:Connect(function() ToggleScrollingAncestors(dropFrame, true) end)

	local listLayout = Instance.new("UIListLayout", listContainer)
	listLayout.SortOrder = Enum.SortOrder.LayoutOrder
	listLayout.Padding = UDim.new(0, 2)

	local optionItems = {}

	local function CloseDropdown()
		isOpen = false
		divider.Visible = false
		listContainer.Visible = false
		TweenService:Create(arrowIcon, TweenInfo.new(0.2), {Rotation = 0}):Play()
	end

	local function UpdateOptionVisuals()
		for _, btn in ipairs(optionItems) do
			local txt = string.sub(btn.Text, 3)
			local isActive = false
			if multi then
				isActive = table.find(selected, txt) ~= nil
			else
				isActive = (txt == tostring(selected))
			end
			
			if isActive then
				btn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
				btn.TextColor3 = strokeColor or Color3.fromRGB(0, 160, 255)
			else
				btn.BackgroundColor3 = Color3.fromRGB(24, 24, 28)
				btn.TextColor3 = Color3.fromRGB(200, 200, 200)
			end
		end
	end

	local function Refresh(newOptions)
		for _, item in ipairs(optionItems) do
			item:Destroy()
		end
		table.clear(optionItems)

		options = type(newOptions) == "table" and newOptions or {}

		for _, opt in ipairs(options) do
			local optStr = tostring(opt)
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1, -8, 0, 30)
			btn.BackgroundColor3 = Color3.fromRGB(24, 24, 28)
			btn.BorderSizePixel = 0
			btn.Text = "  " .. optStr
			btn.TextColor3 = Color3.fromRGB(200, 200, 200)
			btn.Font = Enum.Font.Gotham
			btn.TextSize = 13
			btn.TextXAlignment = Enum.TextXAlignment.Left
			btn.Parent = listContainer
			Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)

			btn.MouseEnter:Connect(function()
				TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(35, 35, 40), TextColor3 = Color3.fromRGB(255,255,255)}):Play()
			end)
			btn.MouseLeave:Connect(function()
				local isActive = false
				if multi then isActive = table.find(selected, optStr) ~= nil else isActive = (optStr == tostring(selected)) end
				local targetColor = isActive and Color3.fromRGB(30, 30, 35) or Color3.fromRGB(24, 24, 28)
				local targetText = isActive and (strokeColor or Color3.fromRGB(0, 160, 255)) or Color3.fromRGB(200, 200, 200)
				TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = targetColor, TextColor3 = targetText}):Play()
			end)

			btn.MouseButton1Click:Connect(function()
				if multi then
					local idx = table.find(selected, optStr)
					if idx then table.remove(selected, idx) else table.insert(selected, optStr) end
					selectedLabel.Text = GetSelectedText()
					UpdateOptionVisuals()
					if typeof(callback) == "function" then task.spawn(callback, selected) end
				else
					selected = optStr
					selectedLabel.Text = GetSelectedText()
					CloseDropdown()
					UpdateOptionVisuals()
					if typeof(callback) == "function" then task.spawn(callback, selected) end
				end
			end)

			table.insert(optionItems, btn)
		end

		UpdateOptionVisuals()

		local maxItems = 4.5
		local totalItems = #options
		local height = math.min(totalItems, maxItems) * 32
		listContainer.Size = UDim2.new(1, -16, 0, height)
	end

	Refresh(options)

	clickBtn.MouseButton1Click:Connect(function()
		isOpen = not isOpen
		if isOpen then
			divider.Visible = true
			listContainer.Visible = true
			TweenService:Create(arrowIcon, TweenInfo.new(0.2), {Rotation = 180}):Play()
		else
			CloseDropdown()
		end
	end)

	return {
		Wrapper = wrapper,
		Frame = dropFrame,
		GetValue = function() return selected end,
		SetValue = function(self, val)
			if multi then
				selected = type(val) == "table" and val or {tostring(val)}
			else
				selected = tostring(val)
			end
			selectedLabel.Text = GetSelectedText()
			UpdateOptionVisuals()
			if typeof(callback) == "function" then
				task.spawn(callback, selected)
			end
		end,
		Refresh = function(self, newOpts)
			Refresh(newOpts)
		end
	}
end

-- Helper: Gumawa ng Paragraph Component
local function CreateParagraph(parentFrame, strokeColor, config)
	config = type(config) == "table" and config or {Title = tostring(config)}
	local title = tostring(config.Title or "")
	local body = tostring(config.Content or config.Description or "")
	
	local measuredWidth = 598 * 0.92
	if parentFrame and parentFrame.AbsoluteSize and parentFrame.AbsoluteSize.X > 0 then
		measuredWidth = parentFrame.AbsoluteSize.X * 0.95
	end
	
	local titleHeight = 0
	if title ~= " " and title ~= "" then
		local ts = TextService:GetTextSize(title, 16, Enum.Font.GothamBold, Vector2.new(measuredWidth - 24, 1000))
		titleHeight = math.max(18, math.ceil(ts.Y))
	end
	
	local bodySize = TextService:GetTextSize(body, 14, Enum.Font.Gotham, Vector2.new(measuredWidth - 24, 2000))
	local bodyHeight = math.ceil(bodySize.Y)
	local totalHeight = 6 + titleHeight + (body ~= "" and 3 or 0) + bodyHeight + 6
	
	local wrapper = Instance.new("Frame")
	wrapper.Name = "ParagraphWrapper"
	wrapper.Size = UDim2.new(1, 0, 0, 0)
	wrapper.BackgroundTransparency = 1
	wrapper.Parent = parentFrame
	wrapper.AutomaticSize = Enum.AutomaticSize.Y
	
	local paraFrame = Instance.new("Frame")
	paraFrame.Name = "Paragraph"
	paraFrame.AnchorPoint = Vector2.new(0.5, 0)
	paraFrame.Position = UDim2.new(0.5, 0, 0, 3)
	paraFrame.Size = UDim2.new(0.95, 0, 0, totalHeight)
	paraFrame.BackgroundColor3 = Color3.fromRGB(24,24,28)
	paraFrame.BorderSizePixel = 0
	Instance.new("UICorner", paraFrame).CornerRadius = UDim.new(0, 8)
	paraFrame.Parent = wrapper
	
	local glow = Instance.new("Frame")
	glow.Name = "ParagraphGlow"
	glow.AnchorPoint = Vector2.new(0.5, 0)
	glow.Position = UDim2.new(0.5, 0, 0, 1)
	glow.Size = UDim2.new(0.96, 0, 0, totalHeight + 6)
	glow.BackgroundTransparency = 0.96
	glow.BackgroundColor3 = strokeColor or Color3.fromRGB(0,160,255)
	Instance.new("UICorner", glow).CornerRadius = UDim.new(0, 10)
	glow.Parent = wrapper
	StartNeonLoop(glow)
	
	local paraStroke = Instance.new("UIStroke", paraFrame)
	paraStroke.Thickness = 1.5
	paraStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
	paraStroke.Color = strokeColor or Color3.fromRGB(0,160,255)
	StartNeonLoop(paraStroke)
	
	local inner = Instance.new("Frame", paraFrame)
	inner.Size = UDim2.new(1, -16, 1, -12)
	inner.Position = UDim2.fromOffset(8, 6)
	inner.BackgroundTransparency = 1
	
	if title ~= " " and title ~= "" then
		local ptitleLabel = Instance.new("TextLabel", inner)
		ptitleLabel.Name = "ParagraphTitle"
		ptitleLabel.Size = UDim2.new(1,0,0,titleHeight)
		ptitleLabel.Position = UDim2.fromOffset(0,0)
		ptitleLabel.BackgroundTransparency = 1
		ptitleLabel.Text = title
		ptitleLabel.TextColor3 = Color3.fromRGB(255,255,255)
		ptitleLabel.Font = Enum.Font.GothamBold
		ptitleLabel.TextSize = 15
		ptitleLabel.TextXAlignment = Enum.TextXAlignment.Left
		ptitleLabel.TextWrapped = true
	end
	
	local bodyLabel = Instance.new("TextLabel", inner)
	bodyLabel.Name = "ParagraphBody"
	bodyLabel.Size = UDim2.new(1,0,0,bodyHeight)
	bodyLabel.Position = UDim2.fromOffset(0, titleHeight + 3)
	bodyLabel.BackgroundTransparency = 1
	bodyLabel.Text = body
	bodyLabel.TextColor3 = Color3.fromRGB(255,255,255)
	bodyLabel.Font = Enum.Font.Gotham
	bodyLabel.TextSize = 13
	bodyLabel.TextWrapped = true
	bodyLabel.TextXAlignment = Enum.TextXAlignment.Left
	bodyLabel.TextYAlignment = Enum.TextYAlignment.Top
	
	local paraAPI = {
		Wrapper = wrapper,
		Frame = paraFrame,
		BodyLabel = bodyLabel,
		SetText = function(self, newText)
			newText = tostring(newText or " ")
			bodyLabel.Text = newText
			task.defer(function()
				local w = measuredWidth
				if parentFrame and parentFrame.AbsoluteSize and parentFrame.AbsoluteSize.X > 0 then
					w = parentFrame.AbsoluteSize.X * 0.95
				end
				local newTitleH = 0
				if title ~= " " and title ~= "" then
					local ts2 = TextService:GetTextSize(title, 15, Enum.Font.GothamBold, Vector2.new(w - 24, 1000))
					newTitleH = math.max(18, math.ceil(ts2.Y))
				end
				local newBodySize = TextService:GetTextSize(newText, 13, Enum.Font.Gotham, Vector2.new(w - 24, 2000))
				local newBodyH = math.ceil(newBodySize.Y)
				local newTotal = 6 + newTitleH + 3 + newBodyH + 6
				paraFrame.Size = UDim2.new(0.95, 0, 0, newTotal)
				glow.Size = UDim2.new(0.96, 0, 0, newTotal + 6)
				wrapper.Size = UDim2.new(1, 0, 0, newTotal + 8)
				if paraFrame:FindFirstChild("ParagraphTitle") then
					paraFrame.ParagraphTitle.Size = UDim2.new(1, 0, 0, newTitleH)
				end
				bodyLabel.Size = UDim2.new(1, 0, 0, newBodyH)
			end)
		end,
	}
	return paraAPI
end

