	KazeUI:AddPanel(SideBar, 0.01)
	SideBar.Parent = SideBarMask

	local VertDivider = Instance.new("Frame")
	VertDivider.Size, VertDivider.Position, VertDivider.BorderSizePixel = UDim2.new(0,1,1,0), UDim2.new(0,190,0,0), 0
	KazeUI:OnThemeChanged(VertDivider, function(t) VertDivider.BackgroundColor3 = t.Border end)
	VertDivider.Parent = Content

	local Pages = Instance.new("Frame")
	Pages.Position, Pages.Size, Pages.BorderSizePixel = UDim2.new(0,191,0,0), UDim2.new(1, -191, 1, 0), 0
	KazeUI:AddPanel(Pages, -0.01)
	Pages.Parent = Content

	local isSidebarOpen = true
	Avatar.MouseButton1Click:Connect(function()
		isSidebarOpen = not isSidebarOpen
		if isSidebarOpen then
			PlayTween(SideBarMask, TWEENS.Smooth, {Size = UDim2.new(0, 190, 1, 0)})
			PlayTween(VertDivider, TWEENS.Smooth, {Position = UDim2.new(0, 190, 0, 0), BackgroundTransparency = 0})
			PlayTween(Pages, TWEENS.Smooth, {Position = UDim2.new(0, 191, 0, 0), Size = UDim2.new(1, -191, 1, 0)})
		else
			PlayTween(SideBarMask, TWEENS.Smooth, {Size = UDim2.new(0, 0, 1, 0)})
			PlayTween(VertDivider, TWEENS.Smooth, {Position = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1})
			PlayTween(Pages, TWEENS.Smooth, {Position = UDim2.new(0, 0, 0, 0), Size = UDim2.new(1, 0, 1, 0)})
		end
	end)

	local TabsScroller = Instance.new("ScrollingFrame")
	TabsScroller.Position, TabsScroller.Size, TabsScroller.BackgroundTransparency = UDim2.fromOffset(6,6), UDim2.new(1, -12, 1, -12), 1
	TabsScroller.ScrollBarThickness, TabsScroller.CanvasSize, TabsScroller.AutomaticCanvasSize, TabsScroller.ScrollBarImageColor3 = 4, UDim2.new(0, 0, 0, 0), Enum.AutomaticSize.Y, Color3.fromRGB(40,40,45)
	TabsScroller.Parent = SideBar

	local TabsList = Instance.new("Frame")
	TabsList.BackgroundTransparency, TabsList.Size, TabsList.AutomaticSize = 1, UDim2.new(1, 0, 0, 0), Enum.AutomaticSize.Y
	local tabsLayout = Instance.new("UIListLayout", TabsList)
	tabsLayout.SortOrder, tabsLayout.Padding = Enum.SortOrder.LayoutOrder, UDim.new(0,4)
	TabsList.Parent = TabsScroller

	-- Smooth Resizing
	local ResizeHandle = Instance.new("ImageLabel")
	ResizeHandle.Name, ResizeHandle.Size, ResizeHandle.Position, ResizeHandle.BackgroundTransparency = "ResizeHandle", UDim2.fromOffset(18, 18), UDim2.new(1, -18, 1, -18), 1
	ResizeHandle.Image, ResizeHandle.Active, ResizeHandle.ZIndex = "rbxassetid://10747373117", true, 99
	KazeUI:OnThemeChanged(ResizeHandle, function(t) ResizeHandle.ImageColor3 = t.MutedText end)
	ResizeHandle.Parent = Window

	local isResizing, resizeStartSize, resizeStartInput, resizeTouchInput = false, Vector2.new(0, 0), Vector3.new(0, 0, 0), nil
	local hoverCursor = "rbxassetid://10747373117"

	ResizeHandle.MouseEnter:Connect(function()
		if not isResizing and not toggledMaximized then Mouse.Icon = hoverCursor; PlayTween(ResizeHandle, TWEENS.Fast, {ImageColor3 = KazeUI.GlowColor}) end
	end)
	ResizeHandle.MouseLeave:Connect(function()
		if not isResizing then Mouse.Icon = ""; PlayTween(ResizeHandle, TWEENS.Fast, {ImageColor3 = KazeUI.CurrentTheme.MutedText}) end
	end)

	local function UpdateResize(input)
		if not isResizing then return end
		local delta, scale = input.Position - resizeStartInput, UIScale.Scale
		Window.Size = UDim2.fromOffset(math.clamp(resizeStartSize.X + (delta.X / scale), minWidth, maxWidth), math.clamp(resizeStartSize.Y + (delta.Y / scale), minHeight, maxHeight))
		lastNormalSize = Window.Size
	end

	ResizeHandle.InputBegan:Connect(function(input)
		if toggledMaximized then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			if input.UserInputType == Enum.UserInputType.Touch and resizeTouchInput == nil then resizeTouchInput = input end
			isResizing, resizeStartSize, resizeStartInput = true, Vector2.new(Window.AbsoluteSize.X / UIScale.Scale, Window.AbsoluteSize.Y / UIScale.Scale), input.Position
			LockCamera(); ToggleScrollingAncestors(ResizeHandle, false); Mouse.Icon = hoverCursor
		end
	end)

	UIS.InputChanged:Connect(function(input)
		if isResizing then
			if input.UserInputType == Enum.UserInputType.Touch and input ~= resizeTouchInput then return end
			if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then UpdateResize(input) end
		end
	end)

	UIS.InputEnded:Connect(function(input)
		if isResizing then
			if input.UserInputType == Enum.UserInputType.Touch and input ~= resizeTouchInput then return end
			isResizing, resizeTouchInput = false, nil
			UnlockCamera(); ToggleScrollingAncestors(ResizeHandle, true); Mouse.Icon = ""
			PlayTween(ResizeHandle, TWEENS.Fast, {ImageColor3 = KazeUI.CurrentTheme.MutedText})
		end
	end)

	local Win = {
		Window = Window, ScreenGui = ScreenGui, _Pages = Pages, _TabsList = TabsList, _Tabs = {},
		Minimize = function(self) minimizeWindow() end, Show = function(self) unminimizeWindow() end, Maximize = function(self) unminimizeWindow() end,
		Toggle = function(self) if isMinimized or not Window.Visible then self:Show() else self:Minimize() end end
	}

	function Win:CreateConfigManager(tab)
		local sec = tab:SectionUI("Config Manager")
		local cfgName = "Default"

		local function getConfigs()
			local list = {}
			if listfiles then
				local s, files = pcall(function() return listfiles("") end)
				if not s then s, files = pcall(function() return listfiles("workspace") end) end
				if s and type(files) == "table" then
					for _, f in ipairs(files) do
						local name = string.match(string.match(f, "([^/\\]+)$") or f, "^KazeUI_(.+)%.json$")
						if name then table.insert(list, name) end
					end
				end
			end
			if #list == 0 then table.insert(list, "Default") end
			return list
		end

		sec:TextBox({Title = "Config Name", Default = "Default", Callback = function(v) cfgName = v end})
		local configDropdown
		sec:Button({Title = "Save Config", Callback = function() KazeUI:SaveConfig(cfgName); if configDropdown then configDropdown:Refresh(getConfigs()) end end})
		configDropdown = sec:Dropdown({ Title = "Select Saved Config", Options = getConfigs(), Callback = function(v) cfgName = v end })
		sec:Button({Title = "Refresh Configs", Callback = function() if configDropdown then configDropdown:Refresh(getConfigs()) end end})
		sec:Button({Title = "Load Config", Callback = function() KazeUI:LoadConfig(cfgName) end})
		sec:Button({Title = "Delete Config", Callback = function()
			if delfile then pcall(function() delfile("KazeUI_"..cfgName..".json") end); KazeUI:Notify({Title = "System", Content = "Deleted " .. cfgName}); if configDropdown then configDropdown:Refresh(getConfigs()) end
			else KazeUI:Notify({Title = "Error", Content = "Executor lacks 'delfile' support."}) end
		end})
	end

	function Win:CreateThemeManager(tab)
		local sec = tab:SectionUI("Theme & Visuals")
		local themeNames = {}
		for name, _ in pairs(KazeUI.Themes) do table.insert(themeNames, name) end
		table.sort(themeNames)

		sec:Dropdown({ Title = "Interface Theme Preset", Options = themeNames, Default = KazeUI.CurrentTheme.Name, Flag = "KazeUI_Theme_Preset", Callback = function(val) KazeUI:SetTheme(val) end })
		sec:ColorPicker({ Title = "Accent Glow Color", Default = KazeUI.GlowColor, Flag = "KazeUI_Theme_GlowColor", Callback = function(color) KazeUI:SetGlow(color) end })
		sec:Slider({ Title = "UI Background Transparency", Min = 0, Max = 10, Default = 0, Flag = "KazeUI_Theme_BackgroundTransparency", Callback = function(val) KazeUI:SetTransparency(val / 10) end })
	end

	function Win:CreateTab(arg1, arg2)
		local name = tostring(type(arg1) == "table" and (arg1.Title or arg1.Name) or arg1 or "Tab")
		local formattedIcon = FormatImage(type(arg1) == "table" and arg1.Icon or arg2 or "")
		
		local btn = Instance.new("TextButton")
		btn.Size, btn.BorderSizePixel, btn.Text, btn.AutoButtonColor, btn.ClipsDescendants, btn.LayoutOrder = UDim2.new(1, -12, 0, 40), 0, "", false, true, #self._Tabs + 1
		Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
		KazeUI:AddPanel(btn, 0.02, true)
		btn.Parent = TabsList

		local leftIndicator = Instance.new("Frame")
		leftIndicator.Size, leftIndicator.BackgroundColor3, leftIndicator.BorderSizePixel, leftIndicator.Visible = UDim2.new(0,3,1,0), KazeUI.GlowColor, 0, false
		Instance.new("UICorner", leftIndicator).CornerRadius = UDim.new(0,6)
		KazeUI:OnGlowChanged(leftIndicator, function(c) leftIndicator.BackgroundColor3 = c end)
		leftIndicator.Parent = btn

		local iconLabel = Instance.new("ImageLabel")
		iconLabel.Size, iconLabel.Position, iconLabel.BackgroundTransparency, iconLabel.Image, iconLabel.ScaleType = UDim2.fromOffset(20,20), UDim2.new(0,12,0.5,-10), 1, formattedIcon, Enum.ScaleType.Fit
		iconLabel.Parent = btn
		
		local txt = Instance.new("TextLabel")
		txt.Size, txt.Position, txt.BackgroundTransparency, txt.Text = UDim2.new(1, -44, 1, 0), UDim2.fromOffset(40,0), 1, name
		txt.Font, txt.TextScaled, txt.TextWrapped, txt.TextXAlignment = Enum.Font.Gotham, true, true, Enum.TextXAlignment.Left
		local textConstraint = Instance.new("UITextSizeConstraint", txt)
		textConstraint.MaxTextSize, textConstraint.MinTextSize = 12, 8
		txt.Parent = btn

		local page = Instance.new("Frame")
		page.Size, page.BackgroundTransparency, page.Visible = UDim2.new(1,0,1,0), 1, false
		page.Parent = self._Pages

		local pageContent = Instance.new("ScrollingFrame")
		pageContent.Size, pageContent.BackgroundTransparency, pageContent.BorderSizePixel = UDim2.new(1, 0, 1, 0), 1, 0
		pageContent.ScrollBarThickness, pageContent.CanvasSize, pageContent.AutomaticCanvasSize, pageContent.ScrollBarImageColor3 = 3, UDim2.new(0, 0, 0, 0), Enum.AutomaticSize.Y, Color3.fromRGB(40,40,45)
		
		local pagePadding = Instance.new("UIPadding", pageContent)
		pagePadding.PaddingTop, pagePadding.PaddingBottom, pagePadding.PaddingLeft, pagePadding.PaddingRight = UDim.new(0, 8), UDim.new(0, 8), UDim.new(0, 8), UDim.new(0, 8)
		
		local contentLayout = Instance.new("UIListLayout", pageContent)
		contentLayout.SortOrder, contentLayout.Padding, contentLayout.HorizontalAlignment = Enum.SortOrder.LayoutOrder, UDim.new(0,4), Enum.HorizontalAlignment.Center
		pageContent.Parent = page

		table.insert(self._Tabs, { Button = btn, Indicator = leftIndicator, Label = txt, Page = page, Icon = iconLabel })

		local isHovering = false
		local function activate()
			for _, t in ipairs(self._Tabs) do
				PlayTween(t.Button, TWEENS.Fast, { BackgroundColor3 = KazeUI.GetColor(0.02) })
				t.Indicator.Visible, t.Page.Visible = false, false
				t.Label.TextColor3, t.Icon.ImageColor3, t.Label.Font = KazeUI.CurrentTheme.MutedText, KazeUI.CurrentTheme.MutedText, Enum.Font.Gotham
			end
			PlayTween(btn, TWEENS.Fast, { BackgroundColor3 = KazeUI.GetColor(0.04) })
			leftIndicator.Visible, page.Visible = true, true
			txt.TextColor3, txt.Font = KazeUI.CurrentTheme.Text, Enum.Font.GothamBold
			PlayTween(iconLabel, TWEENS.Fast, { ImageColor3 = KazeUI.GlowColor })
		end

		btn.MouseEnter:Connect(function()
			isHovering = true
			if not leftIndicator.Visible then
				PlayTween(btn, TWEENS.Hover, { BackgroundColor3 = KazeUI.GetColor(0.03) })
				PlayTween(txt, TWEENS.Hover, { TextColor3 = KazeUI.CurrentTheme.Text })
				PlayTween(iconLabel, TWEENS.Hover, { ImageColor3 = KazeUI.CurrentTheme.Text })
			end
		end)
		btn.MouseLeave:Connect(function()
			isHovering = false
			if not leftIndicator.Visible then
				PlayTween(btn, TWEENS.Hover, { BackgroundColor3 = KazeUI.GetColor(0.02) })
				PlayTween(txt, TWEENS.Hover, { TextColor3 = KazeUI.CurrentTheme.MutedText })
				PlayTween(iconLabel, TWEENS.Hover, { ImageColor3 = KazeUI.CurrentTheme.MutedText })
			end
		end)
		btn.MouseButton1Click:Connect(activate)
		if #self._Tabs == 1 then activate() end

		KazeUI:OnThemeChanged(btn, function(t)
			if leftIndicator.Visible then
				txt.TextColor3, btn.BackgroundColor3 = t.Text, KazeUI.GetColor(0.04)
				if not isHovering then iconLabel.ImageColor3 = KazeUI.GlowColor end
			else
				txt.TextColor3, btn.BackgroundColor3 = t.MutedText, KazeUI.GetColor(0.02)
				if not isHovering then iconLabel.ImageColor3 = t.MutedText end
			end
		end)

		local public = { Button = btn, Page = page }
		AttachElementsToAPI(public, pageContent)
		function public:SetText(newText) txt.Text = newText end
		return public
	end

	KazeUI.ActiveWindows[Window] = true
	if typeof(config.Callback) == "function" then pcall(config.Callback) end
	return Win
end

return KazeUI
