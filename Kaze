		contentLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

		table.insert(self._Tabs, { Button = btn, Indicator = leftIndicator, Label = txt, Page = page })

		local function activate()
			for _, t in ipairs(self._Tabs) do
				TweenService:Create(t.Button, TweenInfo.new(0.12), { BackgroundColor3 = KazeUI.GetColor(0.02) }):Play()
				t.Indicator.Visible = false
				t.Page.Visible = false
				t.Label.TextColor3 = Color3.fromRGB(200, 200, 200)
