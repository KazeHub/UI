	paraStroke.Thickness, paraStroke.ApplyStrokeMode = 1.2, Enum.ApplyStrokeMode.Border
	KazeUI:RegisterBorder(paraStroke)
	
	local inner = Instance.new("Frame")
	inner.Size, inner.Position, inner.BackgroundTransparency = UDim2.new(1, -16, 1, -12), UDim2.fromOffset(8, 6), 1
	inner.Parent = paraFrame
	
	local ptitleLabel
	if title ~= " " and title ~= "" then
