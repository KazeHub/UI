	local arrowIcon = Instance.new("ImageLabel")
	arrowIcon.AnchorPoint, arrowIcon.Position, arrowIcon.Size = Vector2.new(1, 0.5), UDim2.new(1, -16, 0.5, 0), UDim2.fromOffset(16, 16)
	arrowIcon.BackgroundTransparency, arrowIcon.Image, arrowIcon.Rotation = 1, "rbxassetid://6031091004", -90
	KazeUI:OnThemeChanged(arrowIcon, function(t) if not isOpen then arrowIcon.ImageColor3 = t.MutedText end end)
	arrowIcon.Parent = headerFrame

	local divider = Instance.new("Frame")
	divider.Size, divider.BorderSizePixel, divider.LayoutOrder, divider.Visible = UDim2.new(0.95, 0, 0, 1), 0, 2, false
	KazeUI:OnThemeChanged(divider, function(t) divider.BackgroundColor3 = t.Border end)
	divider.Parent = sectionBox

	local sectionContent = Instance.new("Frame")
	sectionContent.Name, sectionContent.Size, sectionContent.BackgroundTransparency, sectionContent.BorderSizePixel = "Content", UDim2.new(1, 0, 0, 0), 1, 0
	sectionContent.Visible, sectionContent.AutomaticSize, sectionContent.LayoutOrder = false, Enum.AutomaticSize.Y, 3
	sectionContent.Parent = sectionBox

	local contentLayout = Instance.new("UIListLayout", sectionContent)
	contentLayout.SortOrder, contentLayout.Padding, contentLayout.HorizontalAlignment = Enum.SortOrder.LayoutOrder, UDim.new(0, 5), Enum.HorizontalAlignment.Center

	local contentPadding = Instance.new("UIPadding", sectionContent)
	contentPadding.PaddingTop, contentPadding.PaddingBottom, contentPadding.PaddingLeft, contentPadding.PaddingRight = UDim.new(0, 8), UDim.new(0, 10), UDim.new(0, 4), UDim.new(0, 4)

	local toggleDetector = Instance.new("TextButton")
	toggleDetector.Size, toggleDetector.BackgroundTransparency, toggleDetector.Text, toggleDetector.ZIndex = UDim2.fromScale(1, 1), 1, "", 10
	toggleDetector.Parent = headerFrame

	local function toggleSection()
		isOpen = not isOpen
		sectionContent.Visible, divider.Visible = isOpen, isOpen

		if isOpen then
			PlayTween(arrowIcon, TWEENS.Fast, { Rotation = 0, ImageColor3 = KazeUI.GlowColor })
			PlayTween(accentLine, TWEENS.Fast, { BackgroundColor3 = KazeUI.GlowColor })
			StartNeonLoop(boxStroke); StartNeonLoop(accentLine)
		else
			PlayTween(arrowIcon, TWEENS.Fast, { Rotation = -90, ImageColor3 = KazeUI.CurrentTheme.MutedText })
			PlayTween(accentLine, TWEENS.Fast, { BackgroundColor3 = KazeUI.CurrentTheme.MutedText })
			StopNeonLoop(boxStroke); StopNeonLoop(accentLine)
			boxStroke.Color, accentLine.BackgroundColor3 = KazeUI.CurrentTheme.Border, KazeUI.CurrentTheme.MutedText
		end
	end

	toggleDetector.MouseEnter:Connect(function()
		PlayTween(headerFrame, TWEENS.Hover, { BackgroundColor3 = KazeUI.GetColor(0.04), BackgroundTransparency = 0.4 })
		PlayTween(titleLabel, TWEENS.Hover, { TextColor3 = KazeUI.CurrentTheme.Text })
	end)
	toggleDetector.MouseLeave:Connect(function()
		PlayTween(headerFrame, TWEENS.Hover, { BackgroundTransparency = 1 })
		PlayTween(titleLabel, TWEENS.Hover, { TextColor3 = KazeUI.CurrentTheme.Text })
	end)
	toggleDetector.MouseButton1Down:Connect(function() PlayTween(sectionBox, TweenInfo.new(0.1), { Size = UDim2.new(0.93, 0, 0, 0) }) end)
	toggleDetector.MouseButton1Up:Connect(function() PlayTween(sectionBox, TweenInfo.new(0.1), { Size = UDim2.new(0.95, 0, 0, 0) }); toggleSection() end)

	local sectionPublic = { Frame = sectionBox, ContentFrame = sectionContent, Header = headerFrame }
	AttachElementsToAPI(sectionPublic, sectionContent)
	function sectionPublic:SetText(newText) titleLabel.Text = newText end
	return sectionPublic
end

