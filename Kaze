	end
	BtnRed.MouseButton1Click:Connect(ShowCloseConfirm)

	local Content = Instance.new("Frame")
	Content.Position, Content.Size, Content.BackgroundTransparency = UDim2.fromOffset(0,50), UDim2.new(1,0,1,-50), 1
	Content.Parent = ContentClipper

	local SideBarMask = Instance.new("Frame")
	SideBarMask.Size, SideBarMask.BackgroundTransparency, SideBarMask.ClipsDescendants = UDim2.new(0, 190, 1, 0), 1, true
	SideBarMask.Parent = Content

	local SideBar = Instance.new("Frame")
