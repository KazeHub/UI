-- =========================================================================
-- API ATTACHMENT SYSTEM (Supports both Positional Args and Table Args)
-- This ensures Methods like SectionUI are ALWAYS available!
-- =========================================================================
local function AttachElementsToAPI(apiTable, parentFrame, strokeColor)
	function apiTable:AddLabel(arg1)
		local t = type(arg1) == "table" and (arg1.Text or arg1.Title) or arg1
		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1, -8, 0, 20)
		label.BackgroundTransparency = 1
		label.Text = tostring(t or " ")
		label.TextColor3 = Color3.fromRGB(220,220,220)
		label.Font = Enum.Font.Gotham
		label.TextSize = 13
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.TextWrapped = true
		label.Parent = parentFrame
		return label
	end

	function apiTable:Paragraph(arg1, arg2)
		local title, content
		if type(arg1) == "table" then
			title = arg1.Title
			content = arg1.Content or arg1.Description
		else
			title = arg1
			content = arg2
		end
		return CreateParagraph(parentFrame, strokeColor, title, content)
	end

	function apiTable:Button(arg1, arg2, arg3)
		local title, desc, callback
		if type(arg1) == "table" then
			title = arg1.Title
			desc = arg1.Description or arg1.Content or ""
			callback = arg1.Callback
		else
			title = arg1
			desc = arg2
			callback = arg3
		end
		return CreateClickableParagraph(parentFrame, strokeColor, title, desc, callback)
	end

	function apiTable:Toggle(arg1, arg2, arg3, arg4)
		local title, desc, def, callback
		if type(arg1) == "table" then
			title = arg1.Title
			desc = arg1.Description or arg1.Content or ""
			def = arg1.Default
			callback = arg1.Callback
		else
			title = arg1
			desc = arg2
			def = arg3
			callback = arg4
		end
		return CreateToggleSwitch(parentFrame, strokeColor, title, desc, def, callback)
	end

	function apiTable:TextBox(arg1, arg2, arg3)
		local title, place, callback
		if type(arg1) == "table" then
			title = arg1.Title
			place = arg1.Placeholder
			callback = arg1.Callback
		else
			title = arg1
			place = arg2
			callback = arg3
		end
		return CreateTextBoxInput(parentFrame, strokeColor, title, place, callback)
	end

	function apiTable:Slider(arg1, arg2, arg3, arg4, arg5)
		local title, min, max, def, callback
		if type(arg1) == "table" then
			title = arg1.Title
			min = arg1.Min
			max = arg1.Max
			def = arg1.Default
			callback = arg1.Callback
		else
			title = arg1
			min = arg2
			max = arg3
			def = arg4
			callback = arg5
		end
		return CreateSliderInput(parentFrame, strokeColor, title, min, max, def, callback)
	end

	function apiTable:Dropdown(arg1, arg2, arg3, arg4, arg5)
		local title, vals, def, callback, multi
		if type(arg1) == "table" then
			title = arg1.Title
			vals = arg1.Values or arg1.Options
			def = arg1.Default
			multi = arg1.Multi or false
			callback = arg1.Callback
		else
			title = arg1
			vals = arg2
			def = arg3
			callback = arg4
			multi = arg5 or false
		end
		return CreateDropdown(parentFrame, strokeColor, title, vals, def, callback, multi)
	end

	function apiTable:SectionUI(arg1)
		local title = type(arg1) == "table" and arg1.Title or arg1
		return CreateCollapsibleSection(parentFrame, strokeColor, title)
	end
	
	function apiTable:Section(arg1)
		local title = type(arg1) == "table" and arg1.Title or arg1
		CreateVisualSectionDivider(parentFrame, strokeColor, title)
		return apiTable 
	end

	apiTable.Label = apiTable.AddLabel
	apiTable.AddParagraph = apiTable.Paragraph
	apiTable.AddButton = apiTable.Button
	apiTable.AddToggle = apiTable.Toggle
	apiTable.AddTextBox = apiTable.TextBox
	apiTable.AddSlider = apiTable.Slider
	apiTable.AddDropdown = apiTable.Dropdown
end

