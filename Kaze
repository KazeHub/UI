	local function Refresh(newOptions)
		options = type(newOptions) == "table" and newOptions or {}
		for _, v in pairs(optionItems) do v.btn:Destroy() end
		table.clear(optionItems)
		
		for _, opt in ipairs(options) do
			local optStr = tostring(opt)
			local btn = Instance.new("TextButton", listContainer)
			btn.Size = UDim2.new(1, 0, 0, 28); btn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
			btn.Text = "  " .. optStr; btn.TextColor3 = Color3.fromRGB(200, 200, 200)
