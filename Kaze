		confirmActive, BtnYellow.Active, BtnGreen.Active, BtnRed.Active = true, false, false, false
		
		local Overlay = Instance.new("Frame")
		Overlay.Size, Overlay.BackgroundColor3, Overlay.BackgroundTransparency, Overlay.ZIndex = UDim2.new(1,0,1,0), Color3.fromRGB(0,0,0), 1, 50
