		ConfirmText.Text, ConfirmText.Font, ConfirmText.TextSize, ConfirmText.TextWrapped, ConfirmText.ZIndex = "Do you want to exit KazeUI?", Enum.Font.GothamBold, 13, true, 53
		KazeUI:RegisterText(ConfirmText, false)
		ConfirmText.Parent = ConfirmWindow

		local ButtonsFrame = Instance.new("Frame")
		ButtonsFrame.Size, ButtonsFrame.Position, ButtonsFrame.AnchorPoint, ButtonsFrame.BackgroundTransparency, ButtonsFrame.ZIndex = UDim2.new(1,0,0,40), UDim2.new(0,0,1,-12), Vector2.new(0,1), 1, 53
		local layout = Instance.new("UIListLayout", ButtonsFrame)
		layout.FillDirection, layout.HorizontalAlignment, layout.Padding = Enum.FillDirection.Horizontal, Enum.HorizontalAlignment.Center, UDim.new(0,12)
		ButtonsFrame.Parent = ConfirmWindow

		local ConfirmBtn = Instance.new("TextButton")
		ConfirmBtn.Size, ConfirmBtn.BackgroundColor3, ConfirmBtn.Text, ConfirmBtn.TextColor3 = UDim2.new(0,100,0,30), Color3.fromRGB(239, 68, 68), "Confirm", Color3.fromRGB(255,255,255)
		ConfirmBtn.Font, ConfirmBtn.TextSize, ConfirmBtn.ZIndex = Enum.Font.GothamBold, 12, 54
		Instance.new("UICorner", ConfirmBtn).CornerRadius = UDim.new(0,6)
		ConfirmBtn.Parent = ButtonsFrame

		local CancelBtn = Instance.new("TextButton")
		CancelBtn.Size, CancelBtn.Text, CancelBtn.Font, CancelBtn.TextSize, CancelBtn.ZIndex = UDim2.new(0,100,0,30), "Cancel", Enum.Font.GothamBold, 12, 54
		Instance.new("UICorner", CancelBtn).CornerRadius = UDim.new(0,6)
		KazeUI:AddPanel(CancelBtn, 0.04)
		KazeUI:RegisterText(CancelBtn, true)
		CancelBtn.Parent = ButtonsFrame

		ConfirmBtn.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)
		CancelBtn.MouseButton1Click:Connect(function() 
			PlayTween(Overlay, TWEENS.Fast, {BackgroundTransparency = 1})
			local tw = PlayTween(ConfirmWindow, TWEENS.Fast, {Position = UDim2.fromScale(0.5,0.45)})
			if tw then tw.Completed:Wait() end
			Overlay:Destroy()
			confirmActive, BtnYellow.Active, BtnGreen.Active, BtnRed.Active = false, true, true, true 
