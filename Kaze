-- DEVICE & SCREEN ADAPTIVE SCALING ENGINE
local function UpdateScale()
	local size = workspace.CurrentCamera.ViewportSize
	local width = size.X
	local height = size.Y
	local minAxis = math.min(width, height)
	
	local targetScale = 1.0

	if UIS.TouchEnabled then
		-- Mobile Devices (Phones vs Tablets)
		if minAxis < 500 then
			-- Phone Resolution Layouts
			targetScale = 0.85
		else
			-- Tablet Layouts
			targetScale = 1.0
		end
	else
		-- Desktop / PC Layouts
		if width >= 1920 or height >= 1080 then
			-- Large Monitor Resolution
			targetScale = 1.15
		elseif width <= 1366 then
			-- Lower laptop screen resolutions / smaller physical monitors
			targetScale = 0.95
		else
			-- Standard PC Desktop Size
			targetScale = 1.0
		end
	end

	UIScale.Scale = targetScale
	ScreenGui.IgnoreGuiInset = true
end

UpdateScale()
workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(UpdateScale)

-- Auto-Icon Fetcher via HttpGet
local IconsMap = {}
pcall(function()
	if game and game.HttpGet then
		local rawIcons = game:HttpGet("https://raw.githubusercontent.com/KazeHub/UI/refs/heads/main/Icons.lua.txt")
		if rawIcons then
			local s, res = pcall(function()
				local func = loadstring(rawIcons)
				return func and func()
			end)
			
			if not s or type(res) ~= "table" then
				s, res = pcall(function() return HttpService:JSONDecode(rawIcons) end)
			end
			
			if type(res) == "table" then
				for k, v in pairs(res) do IconsMap[string.lower(tostring(k))] = tostring(v) end
			end
		end
	end
end)

local function FormatImage(id)
	if not id or id == "" then return "" end
	id = tostring(id)
	local lowerId = string.lower(id)
	if IconsMap[lowerId] then
		local mapped = IconsMap[lowerId]
		if not string.find(mapped, "rbxassetid://") and not string.find(mapped, "http") then
			local clean = string.gsub(mapped, "%D", "")
			if clean ~= "" then return "rbxassetid://" .. clean end
		end
		return mapped
	end
	
	if string.find(id, "rbxassetid://") or string.find(id, "http") then return id end
	local clean = string.gsub(id, "%D", "")
	if clean == "" then return id end
	return "rbxassetid://" .. clean
end

-- Threshold dragging to prevent minimize misclicks (Scale-adjusted for fluid dragging)
local function MakeDraggable(dragPart, targetPart)
	local dragging = false
	local dragInput, dragStart, startPos
	local dragActive = false
	
	local function update(input)
		if not dragStart or not startPos then return end
		local delta = input.Position - dragStart
		local scale = UIScale.Scale
		
		if dragActive or delta.Magnitude > 8 then
			dragActive = true
			targetPart.Position = UDim2.new(
				startPos.X.Scale, startPos.X.Offset + (delta.X / scale),
				startPos.Y.Scale, startPos.Y.Offset + (delta.Y / scale)
			)
		end
	end
	
	dragPart.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragActive = false
			dragStart = input.Position
			startPos = targetPart.Position
			
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
					dragInput = nil
				end
			end)
		end
	end)
	
	dragPart.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if input == dragInput and dragging then update(input) end
	end)
end

-- ==========================================
-- Smart Color & Transparency Engines
-- ==========================================
function KazeUI.GetColor(elevation)
	local h, s, v = Color3.toHSV(KazeUI.BackgroundColor)
	local offset = v > 0.5 and -elevation or elevation
	return Color3.fromHSV(h, s, math.clamp(v + offset, 0, 1))
end

function KazeUI:AddPanel(inst, elevation)
	table.insert(KazeUI.PanelElements, {Inst = inst, Elevation = elevation or 0})
	if inst and inst:IsA("GuiObject") then
		inst.BackgroundColor3 = KazeUI.GetColor(elevation or 0)
		-- Prevent Memory Leak
		inst.Destroying:Connect(function()
			for i = #KazeUI.PanelElements, 1, -1 do
				if KazeUI.PanelElements[i].Inst == inst then table.remove(KazeUI.PanelElements, i) end
			end
		end)
	end
end

function KazeUI:AddTransparentElement(inst, defaultTrans)
	table.insert(KazeUI.TransparentElements, {Inst = inst, Default = defaultTrans or inst.BackgroundTransparency})
	-- Prevent Memory Leak
	inst.Destroying:Connect(function()
		for i = #KazeUI.TransparentElements, 1, -1 do
			if KazeUI.TransparentElements[i].Inst == inst then table.remove(KazeUI.TransparentElements, i) end
		end
	end)
end

function KazeUI:SetBackgroundColor(color)
	KazeUI.BackgroundColor = color
	for _, data in ipairs(KazeUI.PanelElements) do
		if data.Inst and data.Inst.Parent and data.Inst:IsA("GuiObject") then
			data.Inst.BackgroundColor3 = KazeUI.GetColor(data.Elevation)
		end
	end
end

function KazeUI:SetTransparency(alpha)
	for _, data in ipairs(KazeUI.TransparentElements) do
		if data.Inst and data.Inst.Parent then
			data.Inst.BackgroundTransparency = math.clamp(data.Default + alpha, 0, 1)
		end
	end
end

local function StartNeonLoop(target)
	if not target then return end
	local propName = pcall(function() return target.Color end) and "Color" or "BackgroundColor3"

	table.insert(KazeUI.GlowElements, {Target = target, Prop = propName})

	local function createTween()
		local tweenInfo = TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
		local h, s, v = Color3.toHSV(KazeUI.GlowColor)
		local targetColor = Color3.fromHSV(h, s, 1)
		local tween = TweenService:Create(target, tweenInfo, { [propName] = targetColor })
		tween:Play()
		KazeUI.NeonTweens[target] = tween
	end
	target[propName] = KazeUI.GlowColor
	createTween()
end

local function StopNeonLoop(target)
	if not target then return end
	if KazeUI.NeonTweens[target] then
		KazeUI.NeonTweens[target]:Cancel()
		KazeUI.NeonTweens[target] = nil
	end
	for i = #KazeUI.GlowElements, 1, -1 do
		if KazeUI.GlowElements[i].Target == target then
			table.remove(KazeUI.GlowElements, i)
		end
	end
end

function KazeUI:SetGlow(color)
	KazeUI.GlowColor = color
	for _, data in ipairs(KazeUI.GlowElements) do
		local target = data.Target
		local propName = data.Prop
		if target and target.Parent then
			if KazeUI.NeonTweens[target] then KazeUI.NeonTweens[target]:Cancel() end
			target[propName] = color
			local tweenInfo = TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
			local h, s, v = Color3.toHSV(color)
			local targetColor = Color3.fromHSV(h, s, 1)
			local newTween = TweenService:Create(target, tweenInfo, { [propName] = targetColor })
			newTween:Play()
			KazeUI.NeonTweens[target] = newTween
		else
			KazeUI.NeonTweens[target] = nil
		end
	end
end

-- Robust Notification Animation Sequence
function KazeUI:Notify(config)
	config = config or {}
	local title = tostring(config.Title or "Notification")
	local content = tostring(config.Content or "")
	local duration = tonumber(config.Duration) or 3

	local notifHolder = Instance.new("Frame")
	notifHolder.Name = "NotifHolder"
	notifHolder.Size = UDim2.new(1, 0, 0, 0)
	notifHolder.BackgroundTransparency = 1
	notifHolder.BorderSizePixel = 0
	notifHolder.ClipsDescendants = true
	notifHolder.Parent = NotifContainer

	local notifFrame = Instance.new("Frame")
	notifFrame.Name = "NotifFrame"
	notifFrame.Size = UDim2.new(1, -10, 0, 60)
	notifFrame.Position = UDim2.new(1.2, 0, 0, 0)
	notifFrame.BorderSizePixel = 0
	notifFrame.Parent = notifHolder
	Instance.new("UICorner", notifFrame).CornerRadius = UDim.new(0, 8)
	KazeUI:AddPanel(notifFrame, 0.02)
	KazeUI:AddTransparentElement(notifFrame, 0)

	local stroke = Instance.new("UIStroke", notifFrame)
	stroke.Thickness = 1.5
	StartNeonLoop(stroke)

	local titleLab = Instance.new("TextLabel", notifFrame)
	titleLab.Size = UDim2.new(1, -20, 0, 20)
	titleLab.Position = UDim2.fromOffset(10, 8)
	titleLab.BackgroundTransparency = 1
	titleLab.Text = title
	titleLab.TextColor3 = Color3.fromRGB(255, 255, 255)
	titleLab.Font = Enum.Font.GothamBold
	titleLab.TextSize = 14
	titleLab.TextXAlignment = Enum.TextXAlignment.Left
	titleLab.TextTruncate = Enum.TextTruncate.AtEnd

	local contentLab = Instance.new("TextLabel", notifFrame)
	contentLab.Size = UDim2.new(1, -20, 0, 20)
	contentLab.Position = UDim2.fromOffset(10, 30)
	contentLab.BackgroundTransparency = 1
	contentLab.Text = content
	contentLab.TextColor3 = Color3.fromRGB(200, 200, 200)
	contentLab.Font = Enum.Font.Gotham
	contentLab.TextSize = 13
	contentLab.TextXAlignment = Enum.TextXAlignment.Left
	contentLab.TextTruncate = Enum.TextTruncate.AtEnd

	TweenService:Create(notifHolder, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, 70)}):Play()
	TweenService:Create(notifFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0, 5, 0, 0)}):Play()

	task.spawn(function()
		task.wait(duration)
		local outTween = TweenService:Create(notifFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = UDim2.new(1.2, 0, 0, 0)})
		outTween:Play()
		outTween.Completed:Wait()
		
		local shrinkTween = TweenService:Create(notifHolder, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, 0)})
		shrinkTween:Play()
		shrinkTween.Completed:Wait()

		StopNeonLoop(stroke)
		notifHolder:Destroy()
	end)
end

function KazeUI:SaveConfig(name)
	if not name or name == "" then
		KazeUI:Notify({Title = "Config Error", Content = "Config name cannot be empty.", Duration = 3})
		return
	end
	
	local data = {}
	for flag, obj in pairs(KazeUI.Flags) do data[flag] = obj.Get() end
	
	if writefile then
		local success, encoded = pcall(function() return HttpService:JSONEncode(data) end)
		if success then
			writefile("KazeUI_"..name..".json", encoded)
			KazeUI:Notify({Title = "Config Saved", Content = "Successfully saved " .. name, Duration = 3})
		else
			KazeUI:Notify({Title = "Config Error", Content = "Failed to encode settings to JSON.", Duration = 3})
		end
	else
		KazeUI:Notify({Title = "Config Error", Content = "Your executor does not support saving files.", Duration = 3})
	end
end

-- Config loader function
function KazeUI:LoadConfig(name)
	if readfile then
		local s, res = pcall(function() return readfile("KazeUI_"..name..".json") end)
		if s then
			local s2, data = pcall(function() return HttpService:JSONDecode(res) end)
			if s2 and type(data) == "table" then
				for flag, val in pairs(data) do
					if KazeUI.Flags[flag] then KazeUI.Flags[flag].Set(val) end
				end
				KazeUI:Notify({Title = "Config Loaded", Content = "Successfully loaded " .. name, Duration = 3})
			else
				KazeUI:Notify({Title = "Config Error", Content = "Invalid or corrupted config format.", Duration = 3})
			end
		else
			KazeUI:Notify({Title = "Config Error", Content = "Config " .. name .. " not found.", Duration = 3})
		end
	end
end

local function ToggleScrollingAncestors(element, state)
	local current = element.Parent
	while current do
		if current:IsA("ScrollingFrame") then current.ScrollingEnabled = state end
		current = current.Parent
	end
end

