	KazeUI:RegisterText(titleLab, false)
	titleLab.Parent = notifFrame

	local contentLab = Instance.new("TextLabel")
	contentLab.Size, contentLab.Position = UDim2.new(1, -40, 0, 18), UDim2.fromOffset(14, 30)
	contentLab.BackgroundTransparency, contentLab.Text = 1, content
	contentLab.Font, contentLab.TextSize, contentLab.TextXAlignment = Enum.TextXAlignment.Left, 12, Enum.TextXAlignment.Left
	KazeUI:RegisterText(contentLab, true)
	contentLab.Parent = notifFrame

	local progressTrack = Instance.new("Frame")
	progressTrack.Size, progressTrack.Position = UDim2.new(1, -20, 0, 2), UDim2.new(0, 10, 1, -4)
	progressTrack.BorderSizePixel = 0
	Instance.new("UICorner", progressTrack).CornerRadius = UDim.new(1, 0)
	KazeUI:OnThemeChanged(progressTrack, function(t) progressTrack.BackgroundColor3 = t.Border end)
	progressTrack.Parent = notifFrame

	local progressBar = Instance.new("Frame")
	progressBar.Size, progressBar.BorderSizePixel = UDim2.new(1, 0, 1, 0), 0
	Instance.new("UICorner", progressBar).CornerRadius = UDim.new(1, 0)
	StartNeonLoop(progressBar)
	KazeUI:OnGlowChanged(progressBar, function(c) progressBar.BackgroundColor3 = c end)
	progressBar.Parent = progressTrack

	notifFrame.Parent = notifHolder

	-- Fluid Enter Animations
	PlayTween(notifHolder, TWEENS.Smooth, {Size = UDim2.new(1, 0, 0, 74)})
	PlayTween(notifFrame, TWEENS.Spring, {Position = UDim2.new(0, 3, 0, 0)})

	task.spawn(function()
		PlayTween(progressBar, TweenInfo.new(duration, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 1, 0)})
		task.wait(duration)
		
		local out = PlayTween(notifFrame, TWEENS.Spring, {Position = UDim2.new(1.3, 0, 0, 0)})
		if out then out.Completed:Wait() end
		
		local shrink = PlayTween(notifHolder, TWEENS.Fast, {Size = UDim2.new(1, 0, 0, 0)})
		if shrink then shrink.Completed:Wait() end

		StopNeonLoop(progressBar)
		local idx = table.find(ActiveNotifs, notifHolder)
		if idx then table.remove(ActiveNotifs, idx) end
		notifHolder:Destroy()
	end)
end

function KazeUI:SaveConfig(name)
	if not name or name == "" then return KazeUI:Notify({Title = "Error", Content = "Config name required.", Duration = 3}) end
	local data = {}
	for flag, obj in pairs(KazeUI.Flags) do data[flag] = obj.Get() end
	if writefile then
		local s, encoded = pcall(function() return HttpService:JSONEncode(data) end)
		if s then
			writefile("KazeUI_"..name..".json", encoded)
			KazeUI:Notify({Title = "Config Saved", Content = "Successfully saved " .. name, Duration = 3})
		end
	else
		KazeUI:Notify({Title = "Error", Content = "Executor lacks file writing support.", Duration = 3})
	end
end

function KazeUI:LoadConfig(name)
	if readfile then
		local s, res = pcall(function() return readfile("KazeUI_"..name..".json") end)
		if s then
			local s2, data = pcall(function() return HttpService:JSONDecode(res) end)
			if s2 and type(data) == "table" then
				for flag, val in pairs(data) do
					if KazeUI.Flags[flag] then KazeUI.Flags[flag].Set(val) end
				end
				KazeUI:Notify({Title = "Config Loaded", Content = "Successfully loaded " .. name, Duration = 3})
			end
		end
	end
end

local function ToggleScrollingAncestors(element, state)
	local current = element.Parent
	while current do
		if current:IsA("ScrollingFrame") then current.ScrollingEnabled = state end
		current = current.Parent
	end
end

