			sectionContent.BackgroundTransparency = 1
			sectionContent.BorderSizePixel = 0
			sectionContent.Parent = sectionFrame
			sectionContent.AutomaticSize = Enum.AutomaticSize.Y
			local secLayout = Instance.new("UIListLayout", sectionContent)
			secLayout.SortOrder = Enum.SortOrder.LayoutOrder
			secLayout.Padding = UDim.new(0,4)
			secLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
			secLayout.VerticalAlignment = Enum.VerticalAlignment.Top

			local sectionPublic = {}
			sectionPublic.Frame = sectionFrame
			sectionPublic.TitleLabel = titleLabel

			function sectionPublic:AddLabel(text)
				local label = Instance.new("TextLabel")
				label.Size = UDim2.new(1, -30, 0, 18)
				label.BackgroundTransparency = 1
				label.Text = tostring(text or " ")
				label.TextColor3 = Color3.fromRGB(220,220,220)
				label.Font = Enum.Font.Gotham
				label.TextSize = 13
				label.TextXAlignment = Enum.TextXAlignment.Left
				label.TextWrapped = true
				label.Parent = sectionContent
				return label
			end

			function sectionPublic:AddParagraph(ptitle, pbody)
				return CreateParagraph(sectionContent, Win._Stroke.Color, ptitle, pbody)
			end
			
			-- Button inside a Section
			function sectionPublic:Button(btitle, bdesc, callback)
				return CreateClickableParagraph(sectionContent, Win._Stroke.Color, btitle, bdesc, callback)
			end
			
			-- NEW: Toggle Switch inside a Section
			function sectionPublic:Toggle(ttitle, tdesc, defaultState, callback)
				return CreateToggleSwitch(sectionContent, Win._Stroke.Color, ttitle, tdesc, defaultState, callback)
			end

			return sectionPublic
		end

		return public
	end

	-- GetTabs convenience
	function Win:GetTabs()
		local out = {}
		for i,t in ipairs(self._Tabs) do
			table.insert(out, { Index = i, Button = t.Button, Page = t.Page })
		end
		return out
	end

	if typeof(Callback) == "function" then pcall(Callback) end
	return Win
end

return KazeUI
