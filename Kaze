		bodyLabel.TextColor3 = Color3.fromRGB(180,180,180); bodyLabel.Font = Enum.Font.Gotham; bodyLabel.TextSize = 13
		bodyLabel.TextWrapped = true; bodyLabel.TextXAlignment = Enum.TextXAlignment.Left; bodyLabel.AutomaticSize = Enum.AutomaticSize.Y
	end
	
	local switchContainer = Instance.new("Frame", toggleFrame)
	switchContainer.AnchorPoint = Vector2.new(1, 0.5); switchContainer.Position = UDim2.new(1, -8, 0.5, 0)
	switchContainer.Size = UDim2.fromOffset(36, 18); switchContainer.BackgroundColor3 = state and KazeUI.ThemeColor or Color3.fromRGB(40, 40, 45)
	Instance.new("UICorner", switchContainer).CornerRadius = UDim.new(1, 0); ApplyTheme(switchContainer, "BackgroundColor3")
	if not state then switchContainer.BackgroundColor3 = Color3.fromRGB(40,40,45) end
	
	local switchIndicator = Instance.new("Frame", switchContainer)
	switchIndicator.AnchorPoint = Vector2.new(0, 0.5); switchIndicator.Position = state and UDim2.new(1, -16, 0.5, 0) or UDim2.new(0, 2, 0.5, 0)
	switchIndicator.Size = UDim2.fromOffset(14, 14); switchIndicator.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	Instance.new("UICorner", switchIndicator).CornerRadius = UDim.new(1, 0)
	
	local click = Instance.new("TextButton", toggleFrame)
	click.Size = UDim2.new(1, 56, 1, 16); click.Position = UDim2.new(0, -8, 0, -8); click.BackgroundTransparency = 1; click.Text = ""

	local function update(instant)
		local targetPos = state and UDim2.new(1, -16, 0.5, 0) or UDim2.new(0, 2, 0.5, 0)
		local targetBg = state and KazeUI.ThemeColor or Color3.fromRGB(40, 40, 45)
		if instant then
			switchIndicator.Position = targetPos; switchContainer.BackgroundColor3 = targetBg
		else
			TweenService:Create(switchIndicator, TweenInfo.new(0.15), {Position = targetPos}):Play()
			TweenService:Create(switchContainer, TweenInfo.new(0.15), {BackgroundColor3 = targetBg}):Play()
		end
	end

	click.MouseButton1Click:Connect(function()
		state = not state; update(false)
		if typeof(callback) == "function" then task.spawn(callback, state) end
	end)
	
	local api = {
		GetValue = function() return state end,
		SetValue = function(self, val) state = val; update(false); if type(callback)=="function" then task.spawn(callback, state) end end
	}
	KazeUI.Elements[title] = api
	return api
end

-- Smart Argument Parsing for Slider (Decimal Support)
local function CreateSlider(parentFrame, title, min, max, default, arg5, arg6)
	local decimals = 0
	local callback = nil
	if type(arg5) == "number" then
		decimals = arg5; callback = arg6
	elseif type(arg5) == "function" then
		callback = arg5
	end

	local value = math.clamp(default, min, max)
	local wrapper = Instance.new("Frame")
	wrapper.Size = UDim2.new(1, 0, 0, 0); wrapper.BackgroundTransparency = 1; wrapper.Parent = parentFrame; wrapper.AutomaticSize = Enum.AutomaticSize.Y
	
	local sFrame = Instance.new("Frame", wrapper)
	sFrame.AnchorPoint = Vector2.new(0.5, 0); sFrame.Position = UDim2.new(0.5, 0, 0, 3)
	sFrame.Size = UDim2.new(0.95, 0, 0, 48); sFrame.BackgroundColor3 = Color3.fromRGB(24,24,28)
	Instance.new("UICorner", sFrame).CornerRadius = UDim.new(0, 8)
	
	local sStroke = Instance.new("UIStroke", sFrame)
	sStroke.Thickness = 1.5; ApplyTheme(sStroke, "Color")
	
	local titleLabel = Instance.new("TextLabel", sFrame)
	titleLabel.Size = UDim2.new(1, -50, 0, 18); titleLabel.Position = UDim2.new(0, 12, 0, 8); titleLabel.BackgroundTransparency = 1
	titleLabel.Text = title; titleLabel.TextColor3 = Color3.fromRGB(255,255,255)
	titleLabel.Font = Enum.Font.GothamBold; titleLabel.TextSize = 14; titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	
	local valueLabel = Instance.new("TextLabel", sFrame)
	valueLabel.Size = UDim2.new(0, 40, 0, 18); valueLabel.Position = UDim2.new(1, -52, 0, 8); valueLabel.BackgroundTransparency = 1
	valueLabel.Text = tostring(value); valueLabel.TextColor3 = KazeUI.ThemeColor
	valueLabel.Font = Enum.Font.GothamBold; valueLabel.TextSize = 13; valueLabel.TextXAlignment = Enum.TextXAlignment.Right
	ApplyTheme(valueLabel, "TextColor3")
	
	local track = Instance.new("Frame", sFrame)
	track.Size = UDim2.new(1, -24, 0, 6); track.Position = UDim2.new(0, 12, 0, 32); track.BackgroundColor3 = Color3.fromRGB(16, 16, 20)
	Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)
	
	local fill = Instance.new("Frame", track)
	fill.Size = UDim2.new((value - min)/(max - min), 0, 1, 0); fill.BackgroundColor3 = KazeUI.ThemeColor
	Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0); ApplyTheme(fill, "BackgroundColor3")
	
	local knob = Instance.new("Frame", track)
	knob.AnchorPoint = Vector2.new(0.5, 0.5); knob.Size = UDim2.fromOffset(12, 12)
	knob.Position = UDim2.new((value - min)/(max - min), 0, 0.5, 0); knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)
	
	local knobStroke = Instance.new("UIStroke", knob)
	knobStroke.Thickness = 1.5; ApplyTheme(knobStroke, "Color")
	
	local click = Instance.new("TextButton", track)
	click.Size = UDim2.new(1, 0, 1, 20); click.Position = UDim2.new(0, 0, 0, -10); click.BackgroundTransparency = 1; click.Text = ""
	
	local isDragging = false
	local function updateVal(input)
		local perc = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		local newVal = min + (max - min) * perc
		if decimals > 0 then
			local mult = 10^decimals
			newVal = math.floor(newVal * mult + 0.5) / mult
		else
			newVal = math.floor(newVal + 0.5)
		end
		newVal = math.clamp(newVal, min, max)

		value = newVal
		valueLabel.Text = tostring(value)
		
		local visualPerc = (value - min) / (max - min)
		fill.Size = UDim2.new(visualPerc, 0, 1, 0)
		knob.Position = UDim2.new(visualPerc, 0, 0.5, 0)
		
		if typeof(callback) == "function" then task.spawn(callback, value) end
	end
	
	click.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			isDragging = true; ToggleScrollingAncestors(sFrame, false); updateVal(input)
		end
	end)
	UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			isDragging = false; ToggleScrollingAncestors(sFrame, true)
		end
	end)
	UIS.InputChanged:Connect(function(input)
		if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			updateVal(input)
		end
	end)
	
	local api = {
		GetValue = function() return value end,
		SetValue = function(self, val)
			value = math.clamp(tonumber(val) or min, min, max)
			valueLabel.Text = tostring(value)
			local perc = (value - min) / (max - min)
			fill.Size = UDim2.new(perc, 0, 1, 0); knob.Position = UDim2.new(perc, 0, 0.5, 0)
			if typeof(callback) == "function" then task.spawn(callback, value) end
		end
	}
	KazeUI.Elements[title] = api
	return api
end

