-- Smart Argument Parsing for Dropdown (Support for Multi-Select via boolean)
local function CreateDropdown(parentFrame, title, options, defaultOption, arg4, arg5)
	local isMulti = false
	local callback = nil
	if type(arg4) == "boolean" then
		isMulti = arg4; callback = arg5
	elseif type(arg4) == "function" then
		callback = arg4
	end

	local selected
	if isMulti then
		if type(defaultOption) == "table" then selected = defaultOption
		elseif type(defaultOption) == "string" and defaultOption ~= "" then selected = {defaultOption}
		else selected = {} end
	else
		selected = defaultOption or (options[1] or "")
	end

	local isOpen = false
	
	local wrapper = Instance.new("Frame")
