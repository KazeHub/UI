function KazeUI.GetColor(elevation)
	local theme = KazeUI.CurrentTheme
	local h, s, v = Color3.toHSV(theme.Background)
	local offset = elevation * (theme.LightnessFactor or 1)
	return Color3.fromHSV(h, s, math.clamp(v + offset, 0, 1))
end

function KazeUI:AddPanel(inst, elevation, ignoreColorUpdate)
	if not inst then return end
	KazeUI.PanelElements[inst] = { Elevation = elevation or 0, IgnoreColor = ignoreColorUpdate }
	
	if inst:IsA("GuiObject") then
		if not ignoreColorUpdate then inst.BackgroundColor3 = KazeUI.GetColor(elevation or 0) end
		
		local baseTrans = KazeUI.BackgroundTransparency or 0
		if elevation and elevation > 0 then
			baseTrans = math.clamp(baseTrans - (elevation * 0.3), 0, 1)
		elseif elevation and elevation < 0 then
			baseTrans = math.clamp(baseTrans + (math.abs(elevation) * 0.3), 0, 1)
		end
		inst.BackgroundTransparency = baseTrans
	end
end

function KazeUI:SetTransparency(alpha)
	KazeUI.BackgroundTransparency = alpha
	for inst, data in pairs(KazeUI.PanelElements) do
		if inst.Parent and inst:IsA("GuiObject") then
			local elevation, baseTrans = data.Elevation or 0, alpha
			if elevation > 0 then baseTrans = math.clamp(alpha - (elevation * 0.3), 0, 1)
			elseif elevation < 0 then baseTrans = math.clamp(alpha + (math.abs(elevation) * 0.3), 0, 1) end
			inst.BackgroundTransparency = baseTrans
		end
	end
end

function KazeUI:SetTheme(themeName)
	local targetTheme = KazeUI.Themes[themeName] or KazeUI.Themes.Obsidian
	KazeUI.CurrentTheme, KazeUI.BackgroundColor = targetTheme, targetTheme.Background
	
	for inst, data in pairs(KazeUI.PanelElements) do
		if inst.Parent and inst:IsA("GuiObject") and not data.IgnoreColor then
			inst.BackgroundColor3 = KazeUI.GetColor(data.Elevation)
		end
	end
	
	KazeUI:SetTransparency(KazeUI.BackgroundTransparency or 0)
	
	for inst, _ in pairs(KazeUI.TextElements) do
		if inst.Parent then inst.TextColor3 = targetTheme.Text end
	end
	for inst, _ in pairs(KazeUI.MutedTextElements) do
		if inst.Parent then
			inst.TextColor3 = targetTheme.MutedText
			if inst:IsA("TextBox") then inst.PlaceholderColor3 = targetTheme.MutedText end
		end
	end
	for inst, _ in pairs(KazeUI.BorderElements) do
		if inst.Parent then inst.Color = targetTheme.Border end
	end
	for inst, cb in pairs(KazeUI.ThemeCallbacks) do
		if inst.Parent then task.spawn(cb, targetTheme) end
	end
end

local function StartNeonLoop(target)
	if not target then return end
	local propName = pcall(function() return target.Color end) and "Color" or "BackgroundColor3"
	KazeUI.GlowElements[target] = propName

	local function createTween()
		local tInfo = TweenInfo.new(3, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
		local h, s, v = Color3.toHSV(KazeUI.GlowColor)
		local targetColor = Color3.fromHSV(h, s * 0.75, math.clamp(v * 1.2, 0, 1))
		local tween = TweenService:Create(target, tInfo, { [propName] = targetColor })
		tween:Play()
		KazeUI.NeonTweens[target] = tween
	end
	target[propName] = KazeUI.GlowColor
	createTween()
end

local function StopNeonLoop(target)
	if not target then return end
	if KazeUI.NeonTweens[target] then KazeUI.NeonTweens[target]:Cancel(); KazeUI.NeonTweens[target] = nil end
	KazeUI.GlowElements[target] = nil
end

function KazeUI:SetGlow(color)
	KazeUI.GlowColor = color
	for target, propName in pairs(KazeUI.GlowElements) do
		if target.Parent then
			if KazeUI.NeonTweens[target] then KazeUI.NeonTweens[target]:Cancel() end
			target[propName] = color
			local tInfo = TweenInfo.new(3, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true)
			local h, s, v = Color3.toHSV(color)
			local targetColor = Color3.fromHSV(h, s * 0.75, math.clamp(v * 1.2, 0, 1))
			local newTween = TweenService:Create(target, tInfo, { [propName] = targetColor })
			newTween:Play()
			KazeUI.NeonTweens[target] = newTween
		end
	end
	for inst, cb in pairs(KazeUI.GlowCallbacks) do
		if inst.Parent then task.spawn(cb, color) end
	end
end

